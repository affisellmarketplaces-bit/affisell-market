{
  "name": "@affisell/supplier-extension",
  "version": "1.0.0",
  "private": true,
  "description": "Affisell supplier catalog import from product pages",
  "scripts": {
    "build": "node scripts/build.mjs",
    "watch": "node scripts/build.mjs --watch",
    "dev": "npm run watch",
    "db:migrate": "node ../../scripts/prisma-with-env.mjs migrate deploy",
    "db:migrate:status": "node ../../scripts/prisma-with-env.mjs migrate status",
    "db:migrate:dev": "node ../../scripts/prisma-with-env.mjs migrate dev"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "typescript": "^5.8.2"
  }
}
