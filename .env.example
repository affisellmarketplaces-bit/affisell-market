# Copy to Vercel → Project → Settings → Environment Variables (Production)

# UI messages default locale: `en` (see `messages/en.json`, `messages/fr.json`)
# User override: cookie `affisell_locale` (EN/FR switcher in header) or:
# NEXT_PUBLIC_MESSAGES_LOCALE=fr

# EU-first storefront (default). US later: NEXT_PUBLIC_MARKET_REGION=us
NEXT_PUBLIC_MARKET_REGION=eu
# Optional — defaults: EU → en-IE + EUR; US → en-US + USD
# NEXT_PUBLIC_STOREFRONT_LOCALE=en-IE
# NEXT_PUBLIC_STOREFRONT_CURRENCY=EUR

# Production (Vercel): DATABASE_URL required at build (pooled Neon OK)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
# Direct host for Prisma migrate deploy — same DB, host WITHOUT `-pooler` (avoids P1002 advisory lock)
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=60"
# Legacy alias — optional if DATABASE_URL_UNPOOLED is set (scripts auto-sync both)
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=60"
# Dev: direct Neon host by default in `npm run dev` (fewer E57P01 pooler disconnects).
# Opt into pooler locally only if you hit P2024: PRISMA_USE_POOLER_DEV=1
# Legacy alias — same as default dev behavior when DATABASE_URL_UNPOOLED / DIRECT_URL is set:
# PRISMA_USE_DIRECT_DEV=1
# Vercel build: migrations run post-deploy via /api/cron/migrate (not at build time).
# Legacy only — re-enable migrate during build (P1002 risk on Neon pooler):
# BUILD_RUN_MIGRATIONS=1
# Optional — override auto pool tuning (dev default connection_limit=20, pool_timeout=60)
# PRISMA_CONNECTION_LIMIT=20
# PRISMA_POOL_TIMEOUT=60

# Next.js dev server port (default 3001). See also .env.local.example
PORT=3001

# Demo Lab — /demo (feedback in DemoFeedback). Migrate: 20260603140000_demo_feedback
# Vercel Preview: Demo Lab auto-on (VERCEL_ENV=preview). Set DEMO_LAB_PASSWORD on Preview env + redeploy.
# Production: DEMO_LAB_ENABLED=1 + DEMO_LAB_PASSWORD (or DEMO_LAB_ENABLED=0 to force off)
# DEMO_LAB_PASSWORD=""   # required for 1-click login; shared or per-role:
# DEMO_SUPPLIER_PASSWORD=""
# DEMO_AFFILIATE_PASSWORD=""
# DEMO_BUYER_PASSWORD=""
# Local: DEMO_LAB_PASSWORD in .env.local — npm run demo:ensure

# Merchant KYC — comptes inscrits avant cette date = publication autorisée (grandfather)
# MERCHANT_KYC_TRUST_EXISTING=1
# MERCHANT_KYC_MANDATORY_FROM=2026-06-19T00:00:00.000Z

