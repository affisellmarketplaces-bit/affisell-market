# Copy to Vercel → Project → Settings → Environment Variables (Production)

# UI messages default locale: `en` (see `messages/en.json`, `messages/fr.json`)
# User override: cookie `affisell_locale` (EN/FR switcher in header) or:
# NEXT_PUBLIC_MESSAGES_LOCALE=fr

# EU-first storefront (default). US later: NEXT_PUBLIC_MARKET_REGION=us
NEXT_PUBLIC_MARKET_REGION=eu
# Optional — defaults: EU → en-IE + EUR; US → en-US + USD
# NEXT_PUBLIC_STOREFRONT_LOCALE=en-IE
# NEXT_PUBLIC_STOREFRONT_CURRENCY=EUR

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Next.js dev server port (default 3001). If busy, `npm run dev` tries the next free ports automatically.
# PORT=3001

# Local Postgres (no cloud quota): docker compose + npm run db:local:setup
# DATABASE_URL="postgresql://affisell:affisell@localhost:5433/affisell"

# Local-only: production DB URL for `npm run db:copy` (never commit a real value)
# PROD_DB="postgresql://..."

NEXTAUTH_URL="https://your-domain.vercel.app"
NEXTAUTH_SECRET=""

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Groq — AI copy, classification, specs, agent (`/agent`, `/api/products/classify`, supplier drafts)
# Get a key at https://console.groq.com (starts with gsk_)
GROQ_API_KEY=""
# Trust Engine — OpenAI moderation (optional; without key reviews still publish)
OPENAI_API_KEY=""
# Uploadthing — review photo/video UGC
UPLOADTHING_TOKEN=""
UPLOADTHING_APP_ID=""
# PostHog (optional analytics)
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# Universal Auto-Order Engine (BullMQ when REDIS_URL set, else Inngest)
AUTO_ORDER_ENABLED="true"
AUTO_ORDER_ENABLE_STRIPE_TRANSFERS="false"
# Local: docker compose up -d redis  →  redis://127.0.0.1:6379
REDIS_URL=""
AUTO_ORDER_WORKER_CONCURRENCY="4"
# Bull Board (admin): /admin/queues → /admin/queues/board (ADMIN session required)
# Cron: GET /api/cron/sync-supplier-orders (Bearer CRON_SECRET) — poll partner order status
# Cron: GET /api/cron/review-reminder (Bearer CRON_SECRET) — J+7 review email after deliveredAt
# Webhook: POST /api/webhooks/supplier-order (optional HMAC via SUPPLIER_ORDER_WEBHOOK_SECRET)
SUPPLIER_ORDER_WEBHOOK_SECRET=""
# AES-256-GCM for FulfillmentProvider.credentialsEncrypted (falls back to BLIND_DROPSHIP_SECRET)
AFFISELL_FULFILLMENT_SECRET=""
INNGEST_EVENT_KEY=""
# Optional — generate lifestyle illustration when supplier has no description images (supplier generate-description)
# HF_TOKEN=""

# Supabase (required for Affisell Studio processed image persistence)
NEXT_PUBLIC_SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""

# Hugging Face — Affisell Studio inpaint (`/api/inpaint`)
# https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: same value as NEXTAUTH_SECRET (Auth.js also reads AUTH_SECRET)
# AUTH_SECRET=""

# AWS S3 — supplier product images (`POST /api/products/upload`)
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_BUCKET_NAME="affisell-products"

# Universal importer v3
# Required for AliExpress URL import (supplier dashboard → Import → Product URL).
# Get 1,000 free credits at https://www.scrapingbee.com — then set in Vercel env + redeploy.
SCRAPINGBEE_API_KEY=""

# AliExpress Open Service (dropshipping API) — https://openservice.aliexpress.com
# Required on Vercel (Production + Preview): APP_KEY, APP_SECRET, and at least one of:
#   ALIEXPRESS_ACCESS_TOKEN  — from OAuth authorize flow (session on each API call)
#   ALIEXPRESS_REFRESH_TOKEN — auto-refresh access token if ACCESS_TOKEN empty/expired
ALIEXPRESS_APP_KEY=""
ALIEXPRESS_APP_SECRET=""
ALIEXPRESS_ACCESS_TOKEN=""
ALIEXPRESS_REFRESH_TOKEN=""
# sandbox → api-sg.aliexpress.com | production → api.aliexpress.com
ALIEXPRESS_ENV=sandbox
# Sentry (optional). If unset, the SDK stays disabled and the app runs normally.
# Put these in the repo-root `.env.local` (or `.env`). Next.js does not load `prisma/env.local`.
# Client: use NEXT_PUBLIC_SENTRY_DSN so browser events are sent.
# NEXT_PUBLIC_SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"
# Server / Edge (optional override; falls back to NEXT_PUBLIC_SENTRY_DSN):
# SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"
# Source maps during `next build` (local + Vercel when all three are set; never commit the token):
# SENTRY_ORG="your-org-slug"
# SENTRY_PROJECT="your-project-slug"
# SENTRY_AUTH_TOKEN="sntrys_..."  # Organization auth token (releases + source map / artifact scopes)

# Stripe (server)
STRIPE_SECRET_KEY=""
# Webhook signing secret (Stripe Dashboard → Developers → Webhooks → endpoint signing secret)
# Endpoint: https://your-domain.com/api/webhooks/stripe
# Events: checkout.session.completed, customer.subscription.deleted, charge.refunded, invoice.payment_failed
# Billing Portal (Dashboard → Settings → Billing → Customer portal) required for payment-failed emails
# Stripe Tax: enable in Dashboard → Settings → Tax; set business address for automatic_tax on checkout
STRIPE_WEBHOOK_SECRET=""
# VAT flow test: npx tsx scripts/test-vat-flow.ts (Connect Express test account)
TEST_STRIPE_CONNECT_ACCOUNT_ID=""
# Optional pinned product for npm run test:vat (default cmpiddd890003thlps6tp)
# TEST_VAT_PRODUCT_ID=""
# Pro subscription (Veo unlimited videos) — Stripe Dashboard → Products → Price ID
STRIPE_PRO_PRICE_ID=""
NEXT_PUBLIC_APP_URL="http://localhost:3001"
# Blind checkout Payment Element (publishable key, safe for browser)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_…"

# --- Blind dropship (optional; parallel to native marketplace Checkout Session) ---
# AES key for encrypting supplier API keys at rest (min 24 chars).
# BLIND_DROPSHIP_SECRET=""
# Domain used in supplier-facing order emails: commande+{orderId}@{domain}
# BLIND_DROPSHIP_ORDER_EMAIL_DOMAIN="mg.yourdomain.com"
# Inngest (register `/api/inngest` in Inngest dashboard; send events from Stripe webhook).
# INNGEST_EVENT_KEY=""
# Optional: Stripe Connect transfers for COGS (set on supplier profile + enable flag).
# BLIND_DROPSHIP_ENABLE_STRIPE_TRANSFERS="true"
# Ops alert when fulfill fails (optional).
# SLACK_WEBHOOK_URL=""
# Cron auth for `/api/cron/sync-stock` (same pattern as other crons when set).
# CRON_SECRET=""

# --- Product ad video (Veo 3.1 / Meta AI) ---
# VIDEO_API_PROVIDER=veo
# meta = async webhook; veo = sync Vertex (default)
VIDEO_API_PROVIDER=veo
GOOGLE_CLOUD_PROJECT=""
GOOGLE_CLOUD_LOCATION=us-central1
# VEO_MODEL_ID=veo-3.1-generate-001
# Vercel: paste full service account JSON (Vertex AI User). Never commit this value.
GOOGLE_APPLICATION_CREDENTIALS_JSON="colle le JSON ici pour Vercel"
# Local: place affisell-<id>.json at repo root (gitignored), or:
# GOOGLE_APPLICATION_CREDENTIALS=./affisell-xxx.json
# Vercel Blob — required for Veo MP4 upload (videos/{operationId}.mp4)
BLOB_READ_WRITE_TOKEN=""
# Cloudflare R2 — mirror imported supplier videos (URL import)
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_ENDPOINT="https://<account_id>.r2.cloudflarestorage.com"
# R2_PUBLIC_URL="https://pub-xxxx.r2.dev"
# R2_BUCKET_NAME="affisell"
# VEO_POLL_TIMEOUT_MS=90000
# VEO_DURATION_SECONDS=4
# META_AI_API_KEY=""  # when VIDEO_API_PROVIDER=meta

# Resend — order confirmation, tracking, review invites
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Affisell <onboarding@resend.dev>"
# Required when FROM uses onboarding@resend.dev (Resend sandbox only allows your account email)
TEST_EMAIL_TO=""