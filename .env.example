DISABLE_AUTO_BUY=false
# Stripe Issuing virtual card for AE checkout (optional until Issuing enabled)
STRIPE_ISSUING_CARDHOLDER_ID=""
# Browser automation worker (Docker only — never on Vercel serverless)
AE_EMAIL=""
AE_PASSWORD=""
AE_2FA_SECRET=""
