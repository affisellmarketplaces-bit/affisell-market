AUTO_ORDER_WORKER_CONCURRENCY="4"
# Bull Board (admin): /admin/queues → /admin/queues/board (ADMIN session required)
# Cron: GET /api/cron/sync-supplier-orders (Bearer CRON_SECRET) — poll partner order status
# Cron: GET /api/cron/enforce-supplier-ship-sla (Bearer CRON_SECRET) — Ship Pulse after 10d + extension flow
# Cron: GET /api/cron/review-reminder (Bearer CRON_SECRET) — J+7 review email after deliveredAt
# Cron: GET /api/cron/refresh-supplier-trust-scores (Bearer CRON_SECRET) — daily Lightning trust score refresh
# Cron: GET /api/cron/expansion-ops (Bearer CRON_SECRET) — waitlist notify batches, J+2 follow-up, first-order metrics
# Cron: GET /api/cron/expansion-digest?digest=1 via expansion-ops or GET /api/cron/expansion-digest — weekly founder digest
# ADMIN_EXPANSION_DIGEST_EMAIL=""  # optional — defaults to first ADMIN user email
# ROW expansion (Tier 4 C) — preflight: npm run verify:expansion | snapshot: npm run expansion:status
# Pilot CLI: npm run expansion:pilot [-- --no-notify] [-- --country=CH] | Admin UI: /admin/expansion
# Stripe test keys (sk_test_*) OK for preview/local pilots; Production ROW checkout needs sk_live_* + STRIPE_WEBHOOK_SECRET
# Cron: GET /api/cron/expire-sponsor-campaigns (Bearer CRON_SECRET) — expire Promote campaigns
# GitHub Actions: .github/workflows/scheduled-crons.yml (frequent + daily crons)
# Webhook: POST /api/webhooks/supplier-order — required in production (HMAC sha256)
SUPPLIER_ORDER_WEBHOOK_SECRET=""
# AfterShip — Lightning trust score tracking validation + delivery webhook (HMAC sha256, header aftership-hmac-sha256)
AFTERSHIP_API_KEY=""
AFTERSHIP_WEBHOOK_SECRET=""
# Set to 0 to allow « Autre » carrier + format-only validation in dev (never in prod)
SHIP_TRACKING_STRICT=""
# Legacy typo alias (optional) — prefer AFTERSHIP_WEBHOOK_SECRET
# AFTIRSHIP_WEBHOOK_SECRET=""
# AES-256-GCM for FulfillmentProvider.credentialsEncrypted (falls back to BLIND_DROPSHIP_SECRET)
