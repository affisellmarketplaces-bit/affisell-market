# Copy to Vercel → Project → Settings → Environment Variables (Production)

# UI messages: `en` (default) or `fr` (see `messages/fr.json`)
# NEXT_PUBLIC_MESSAGES_LOCALE=fr

# EU-first storefront (default). US later: NEXT_PUBLIC_MARKET_REGION=us
NEXT_PUBLIC_MARKET_REGION=eu
# Optional — defaults: EU → en-IE + EUR; US → en-US + USD
# NEXT_PUBLIC_STOREFRONT_LOCALE=en-IE
# NEXT_PUBLIC_STOREFRONT_CURRENCY=EUR

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Next.js dev server port (default 3001). If busy, `npm run dev` tries the next free ports automatically.
# PORT=3001

# Local Postgres (no cloud quota): docker compose + npm run db:local:setup
# DATABASE_URL="postgresql://affisell:affisell@localhost:5433/affisell"

# Local-only: production DB URL for `npm run db:copy` (never commit a real value)
# PROD_DB="postgresql://..."

NEXTAUTH_URL="https://your-domain.vercel.app"
NEXTAUTH_SECRET=""

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Groq — Personal Shopping Agent (`/agent`, `/api/agent`)
GROQ_API_KEY=""

# Supabase (required for Affisell Studio processed image persistence)
NEXT_PUBLIC_SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""

# Hugging Face — Affisell Studio inpaint (`/api/inpaint`)
# https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: same value as NEXTAUTH_SECRET (Auth.js also reads AUTH_SECRET)
# AUTH_SECRET=""

# AWS S3 — supplier product images (`POST /api/products/upload`)
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_BUCKET_NAME="affisell-products"

# Universal importer v3
SCRAPINGBEE_API_KEY="free_key_here"
# Used by AI routes (OpenAI). On Vercel: value must be the real secret from platform.openai.com/api-keys (starts with sk-),
# not the text "OPENAI_API_KEY" and no wrapping quotes in the dashboard value field.
OPENAI_API_KEY="sk-xxx"

# Sentry (optional). If unset, the SDK stays disabled and the app runs normally.
# Put these in the repo-root `.env.local` (or `.env`). Next.js does not load `prisma/env.local`.
# Client: use NEXT_PUBLIC_SENTRY_DSN so browser events are sent.
# NEXT_PUBLIC_SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"
# Server / Edge (optional override; falls back to NEXT_PUBLIC_SENTRY_DSN):
# SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"
# Source maps during `next build` (local + Vercel when all three are set; never commit the token):
# SENTRY_ORG="your-org-slug"
# SENTRY_PROJECT="your-project-slug"
# SENTRY_AUTH_TOKEN="sntrys_..."  # Organization auth token (releases + source map / artifact scopes)

# Stripe (server)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Blind checkout Payment Element (publishable key, safe for browser)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_…"

# --- Blind dropship (optional; parallel to native marketplace Checkout Session) ---
# AES key for encrypting supplier API keys at rest (min 24 chars).
# BLIND_DROPSHIP_SECRET=""
# Domain used in supplier-facing order emails: commande+{orderId}@{domain}
# BLIND_DROPSHIP_ORDER_EMAIL_DOMAIN="mg.yourdomain.com"
# Inngest (register `/api/inngest` in Inngest dashboard; send events from Stripe webhook).
# INNGEST_EVENT_KEY=""
# Optional: Stripe Connect transfers for COGS (set on supplier profile + enable flag).
# BLIND_DROPSHIP_ENABLE_STRIPE_TRANSFERS="true"
# Ops alert when fulfill fails (optional).
# SLACK_WEBHOOK_URL=""
# Cron auth for `/api/cron/sync-stock` (same pattern as other crons when set).
# CRON_SECRET=""

# --- Product ad video (Veo 3.1 / Meta AI) ---
# VIDEO_API_PROVIDER=veo
# meta = async webhook; veo = sync Vertex (default)
VIDEO_API_PROVIDER=veo
GOOGLE_CLOUD_PROJECT=""
GOOGLE_CLOUD_LOCATION=us-central1
# VEO_MODEL_ID=veo-3.1-generate-001
# Vercel: paste full service account JSON (Vertex AI User). Never commit this value.
GOOGLE_APPLICATION_CREDENTIALS_JSON="colle le JSON ici pour Vercel"
# Local: GOOGLE_APPLICATION_CREDENTIALS=./gcp-service-account.json
# (or place gcp-service-account.json at repo root — gitignored)
# Video storage (first match wins): BLOB_READ_WRITE_TOKEN, or AWS S3, or Supabase bucket product-videos
# BLOB_READ_WRITE_TOKEN=""
# META_AI_API_KEY=""  # when VIDEO_API_PROVIDER=meta
