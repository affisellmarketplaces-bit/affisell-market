# Copy to Vercel → Project → Settings → Environment Variables (Production)

# UI messages default locale: `en` (see `messages/en.json`, `messages/fr.json`)
# User override: cookie `affisell_locale` (EN/FR switcher in header) or:
# NEXT_PUBLIC_MESSAGES_LOCALE=fr

# EU-first storefront (default). US later: NEXT_PUBLIC_MARKET_REGION=us
NEXT_PUBLIC_MARKET_REGION=eu
# Optional — defaults: EU → en-IE + EUR; US → en-US + USD
# NEXT_PUBLIC_STOREFRONT_LOCALE=en-IE
# NEXT_PUBLIC_STOREFRONT_CURRENCY=EUR

# Production (Vercel): DATABASE_URL required at build (pooled Neon OK)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
# Direct host for migrate deploy on Vercel build (recommended — avoids P1001 on pooler)
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=60"
# Emergency only: skip DB steps during Vercel build (schema drift risk)
# BUILD_SKIP_MIGRATIONS=1
# Dev only: bypass pooler (fewer E57P01 "administrator command" disconnects in npm run dev)
# PRISMA_USE_DIRECT_DEV=1

# Next.js dev server port (default 3001). If busy, `npm run dev` tries the next free ports automatically.
# PORT=3001

# Demo Lab — /demo (feedback in DemoFeedback). Migrate: 20260603140000_demo_feedback
# Vercel Preview: Demo Lab auto-on (VERCEL_ENV=preview). Set DEMO_LAB_PASSWORD on Preview env + redeploy.
# Production: DEMO_LAB_ENABLED=1 + DEMO_LAB_PASSWORD (or DEMO_LAB_ENABLED=0 to force off)
# DEMO_LAB_PASSWORD=""   # required for 1-click login; shared or per-role:
# DEMO_SUPPLIER_PASSWORD=""
# DEMO_AFFILIATE_PASSWORD=""
# DEMO_BUYER_PASSWORD=""
# Local: DEMO_LAB_PASSWORD in .env.local — npm run demo:ensure

# Local Postgres (no cloud quota): docker compose + npm run db:local:setup
# DATABASE_URL="postgresql://affisell:affisell@localhost:5433/affisell"

# Local-only: production DB URL for `npm run db:copy` (never commit a real value)
# PROD_DB="postgresql://..."

NEXTAUTH_URL="https://your-domain.vercel.app"
NEXTAUTH_SECRET=""

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Groq — AI copy, classification, specs, agent (`/agent`, `/api/products/classify`, supplier drafts)
# Get a key at https://console.groq.com (starts with gsk_)
GROQ_API_KEY=""
# Trust Engine — OpenAI moderation + affiliate listing copy (GPT-4o generate-description)
OPENAI_API_KEY=""
# Uploadthing — review photo/video UGC
UPLOADTHING_TOKEN=""
UPLOADTHING_APP_ID=""
# PostHog (optional analytics — chargé uniquement après consentement cookies)
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
# Google Analytics (Consent Mode v2 — scripts bloqués jusqu'à acceptation)
NEXT_PUBLIC_GA_MEASUREMENT_ID=""

# Better Stack / Logtail (routes API — obligatoire: token + ingest URL)
LOGTAIL_SOURCE_TOKEN=""
LOGTAIL_URL="https://in.logs.betterstack.com"

# CRM Suppliers Pipeline (Notion) — page /crm (ADMIN)
NOTION_API_KEY=""
NOTION_CRM_DATABASE_ID=""
# Optionnel — scripts/notion-crm-create-database.py
# NOTION_PARENT_PAGE_ID=""

# Universal Auto-Order Engine (BullMQ when REDIS_URL set, else Inngest)
AUTO_ORDER_ENABLED="true"
AUTO_ORDER_ENABLE_STRIPE_TRANSFERS="false"
# Local: docker compose up -d redis  →  redis://127.0.0.1:6379
# Also enables distributed API rate limiting (forgot-password, supplier AI routes).
REDIS_URL=""
AUTO_ORDER_WORKER_CONCURRENCY="4"
# Bull Board (admin): /admin/queues → /admin/queues/board (ADMIN session required)
# Cron: GET /api/cron/sync-supplier-orders (Bearer CRON_SECRET) — poll partner order status
# Cron: GET /api/cron/enforce-supplier-ship-sla (Bearer CRON_SECRET) — Ship Pulse after 10d + extension flow
# Cron: GET /api/cron/review-reminder (Bearer CRON_SECRET) — J+7 review email after deliveredAt
# Cron: GET /api/cron/expire-sponsor-campaigns (Bearer CRON_SECRET) — expire Promote campaigns
# GitHub Actions: .github/workflows/scheduled-crons.yml (frequent + daily crons)
# Webhook: POST /api/webhooks/supplier-order — required in production (HMAC sha256)
SUPPLIER_ORDER_WEBHOOK_SECRET=""
# AES-256-GCM for FulfillmentProvider.credentialsEncrypted (falls back to BLIND_DROPSHIP_SECRET)
AFFISELL_FULFILLMENT_SECRET=""
INNGEST_EVENT_KEY=""
# Optional — generate lifestyle illustration when supplier has no description images (supplier generate-description)
# HF_TOKEN=""

# Supabase (Affisell Studio + fallback supplier media if R2/Blob absent)
NEXT_PUBLIC_SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
# Server-only alias (optional if NEXT_PUBLIC_SUPABASE_URL is set)
# SUPABASE_URL=""

# Hugging Face — Affisell Studio inpaint (`/api/inpaint`)
# https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: same value as NEXTAUTH_SECRET (Auth.js also reads AUTH_SECRET)
# AUTH_SECRET=""

# AWS S3 — supplier product images (`POST /api/products/upload`)
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_BUCKET_NAME="affisell-products"

# Universal importer v3
# Required for AliExpress URL import (supplier dashboard → Import → Product URL).
# Get 1,000 free credits at https://www.scrapingbee.com — then set in Vercel env + redeploy.
SCRAPINGBEE_API_KEY=""

# AliExpress Open Service (dropshipping API) — https://openservice.aliexpress.com
# Required on Vercel (Production + Preview): APP_KEY, APP_SECRET, and at least one of:
#   ALIEXPRESS_ACCESS_TOKEN  — from OAuth authorize flow (session on each API call)
#   ALIEXPRESS_REFRESH_TOKEN — auto-refresh access token if ACCESS_TOKEN empty/expired
ALIEXPRESS_APP_KEY=""
ALIEXPRESS_APP_SECRET=""
ALIEXPRESS_ACCESS_TOKEN=""
ALIEXPRESS_REFRESH_TOKEN=""
# sandbox → api-sg.aliexpress.com | production → api.aliexpress.com
ALIEXPRESS_ENV=sandbox

# Auto-Fulfill (AliExpress auto-buy after paid checkout)
# Kill switch: set to true to skip all auto-buy jobs
DISABLE_AUTO_BUY=false
# Stripe Issuing virtual card for AE checkout (optional until Issuing enabled)
STRIPE_ISSUING_CARDHOLDER_ID=""
# Browser automation worker (Docker only — never on Vercel serverless)
AE_EMAIL=""
AE_PASSWORD=""
AE_2FA_SECRET=""
AE_BROWSER_AUTOMATION_ENABLED=false
# Skip Stripe Issuing + AE order commit; logs prep then marks FulfillmentLog BOUGHT (worker + auto-buy.ts)
AE_DRY_RUN=false

# Sentry (optional). If unset, the SDK stays disabled and the app runs normally.
# Put these in the repo-root `.env.local` (or `.env`). Next.js does not load `prisma/env.local`.
# Client: use NEXT_PUBLIC_SENTRY_DSN so browser events are sent.
# NEXT_PUBLIC_SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"
# Server / Edge (optional override; falls back to NEXT_PUBLIC_SENTRY_DSN):
# SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"
# Source maps during `next build` (local + Vercel when all three are set; never commit the token):
# SENTRY_ORG="your-org-slug"
# SENTRY_PROJECT="your-project-slug"
# SENTRY_AUTH_TOKEN="sntrys_..."  # Organization auth token (releases + source map / artifact scopes)
# Sentinel Sentry collector uses SENTRY_ORG + SENTRY_PROJECT + SENTRY_AUTH_TOKEN (same as above).

# Metabase static embed (optional — Sentinel dashboard iframe)
# METABASE_SITE_URL="https://metabase.example.com"
# METABASE_SECRET_KEY=""  # Admin → Settings → Embedding → Static embedding secret
# METABASE_DASHBOARD_ID="1"

# Stripe (server)
STRIPE_SECRET_KEY=""
# Webhook signing secret (Stripe Dashboard → Developers → Webhooks → endpoint signing secret)
# Endpoint: https://your-domain.com/api/webhooks/stripe
# Events: checkout.session.completed, checkout.session.expired, customer.subscription.deleted, charge.refunded, invoice.payment_failed
# Billing Portal (Dashboard → Settings → Billing → Customer portal) required for payment-failed emails
# Stripe Tax: enable in Dashboard → Settings → Tax; set business address for automatic_tax on checkout
# BNPL (Klarna) on marketplace checkout: enable Klarna in Dashboard → Settings → Payment methods
# MARKETPLACE_BNPL_ENABLED="0"  — card-only fallback without code deploy
STRIPE_WEBHOOK_SECRET=""
# Three-way Connect test (scripts/create-test-order-three-way.ts)
TEST_SUPPLIER_STRIPE_ACCOUNT_ID=""
TEST_AFFILIATE_STRIPE_ACCOUNT_ID=""
# Platform commission in basis points (1200 = 12% HT, 1000 = 10%)
# AFFISELL_COMMISSION_BPS="1200"
# Optional pinned product for npm run test:vat (default cmpiddd890003thlps6tp)
# TEST_VAT_PRODUCT_ID=""
# Pro subscription (Veo unlimited videos) — Stripe Dashboard → Products → Price ID
STRIPE_PRO_PRICE_ID=""
# Video paywall: unset or "1" = paused (unlimited gen, no Pro). Set "0" to re-enable 3 free + Stripe Pro.
# VIDEO_PAYWALL_PAUSED="1"
# Optional extra bypass when pause is off: VIDEO_PAYWALL_DISABLED="1"
NEXT_PUBLIC_APP_URL="http://localhost:3001"
# Merchant custom domains: CNAME target shown in Store profile (default cname.affisell.com)
# STORE_CNAME_TARGET="cname.affisell.com"
# Auto-register verified merchant domains on Vercel (SSL). Create token: Vercel → Settings → Tokens
# VERCEL_API_TOKEN=""
# VERCEL_PROJECT_ID=""   # Project Settings → General → Project ID
# VERCEL_TEAM_ID=""      # Optional, if project is under a team
# Middleware resolves custom hosts via this origin (defaults to NEXT_PUBLIC_APP_URL / VERCEL_URL)
# AFFISELL_PLATFORM_ORIGIN="https://affisell.com"
# Extra platform hostnames (comma-separated), e.g. www.affisell.com
# AFFISELL_PLATFORM_HOSTS="affisell.com,www.affisell.com"
# Blind checkout Payment Element (publishable key, safe for browser)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_…"

# --- Blind dropship (optional; parallel to native marketplace Checkout Session) ---
# AES key for encrypting supplier API keys at rest (min 24 chars).
# BLIND_DROPSHIP_SECRET=""
# Domain used in supplier-facing order emails: commande+{orderId}@{domain}
# BLIND_DROPSHIP_ORDER_EMAIL_DOMAIN="mg.yourdomain.com"
# Inngest (register `/api/inngest` in Inngest dashboard; send events from Stripe webhook).
# INNGEST_EVENT_KEY=""
# Optional: Stripe Connect transfers for COGS (set on supplier profile + enable flag).
# BLIND_DROPSHIP_ENABLE_STRIPE_TRANSFERS="true"
# Ops alerts: blind fulfill failures, Stripe health cron (optional).
# SLACK_WEBHOOK_URL=""
# DISCORD_WEBHOOK_URL=""
# Cron auth for `/api/cron/sync-stock`, `/api/cron/sync-shopify`, etc. (when set).
# CRON_SECRET=""  # Vercel + GitHub Actions (process-transfers workflow)
# BOOKING_HOLD_MINUTES="30"  # Stripe checkout seat hold (default 30, min 5 max 120)
# BOOKING_HOLD_MINUTES_SERVICE="45"  # Coiffeur / rendez-vous
# BOOKING_HOLD_MINUTES_EXPERIENCE="12"  # Cinéma / événements
# VERCEL_APP_URL="https://your-app.vercel.app"  # GitHub secret for transfer cron

# --- Product ad video (Veo 3.1 / Meta AI) ---
# VIDEO_API_PROVIDER=veo
# meta = async webhook; veo = sync Vertex (default)
VIDEO_API_PROVIDER=veo
GOOGLE_CLOUD_PROJECT=""
GOOGLE_CLOUD_LOCATION=us-central1
# VEO_MODEL_ID=veo-3.1-generate-001
# Vercel: paste full service account JSON (Vertex AI User). Never commit this value.
GOOGLE_APPLICATION_CREDENTIALS_JSON="colle le JSON ici pour Vercel"
# Local: place affisell-<id>.json at repo root (gitignored), or:
# GOOGLE_APPLICATION_CREDENTIALS=./affisell-xxx.json
# Vercel Blob — required for Veo MP4 upload (videos/{operationId}.mp4)
BLOB_READ_WRITE_TOKEN=""
# Cloudflare R2 — mirror imported supplier videos (URL import)
# Cloudflare R2 — preferred for supplier photos/videos (variants, Veo refs)
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_ENDPOINT="https://<account_id>.r2.cloudflarestorage.com"
# R2_PUBLIC_URL="https://pub-xxxx.r2.dev"
# R2_BUCKET_NAME="affisell"
# VEO_POLL_TIMEOUT_MS=90000
# VEO_DURATION_SECONDS=4
# META_AI_API_KEY=""  # when VIDEO_API_PROVIDER=meta

# Société — source unique pages légales, markdown, factures, footer
# Clés lues par readCompanyLegal() — alias legacy AFFISELL_* / NEXT_PUBLIC_COMPANY_* supportés
COMPANY_NAME="Affisell SAS"
COMPANY_SIRET=""
COMPANY_ADDRESS=""
COMPANY_CAPITAL=""
COMPANY_VAT=""
PUBLISHER_NAME=""
COMPANY_CONTACT_EMAIL="contact@affisell.com"
SUPPORT_EMAIL="support@affisell.com"
DPO_EMAIL="dpo@affisell.com"
# Médiateur consommation (L.612-1) — affiché sur /mentions-legales
MEDIATOR_URL="https://www.cm2c.net"
MEDIATION_ORG="CM2C"

# Resend — order confirmation, tracking, review invites, password reset, formulaire contact
RESEND_API_KEY=""
# Production (Vercel): use your verified domain — e.g. Affisell <noreply@affisell.com>
# Local dev only: onboarding@resend.dev + TEST_EMAIL_TO below
RESEND_FROM_EMAIL="Affisell <onboarding@resend.dev>"
# Local dev only (onboarding@resend.dev): MUST be your Resend account email
# (Resend sandbox rejects any other recipient — see 403 in scripts/test-resend.ts)
# Example: affisellmarketplaces@gmail.com
TEST_EMAIL_TO=""
# EU storefront — public legal placeholders (footer / mentions)
NEXT_PUBLIC_COMPANY_NAME=""
NEXT_PUBLIC_COMPANY_ADDRESS=""
NEXT_PUBLIC_COMPANY_SIREN=""
NEXT_PUBLIC_COMPANY_VAT=""
NEXT_PUBLIC_MEDIATOR_URL=""
