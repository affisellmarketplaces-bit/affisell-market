generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("MARKET_INTELLI_DATABASE_URL")
}

enum MarketplaceCode {
  TIKTOK_SHOP
  AMAZON
  EBAY
  ALIEXPRESS
  SHOPEE
  GOOGLE_TRENDS
}

model User {
  id        String   @id @default(cuid())
  clerkUserId String @unique
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shops     Shop[]
  connections ShopConnection[]
}

model Shop {
  id        String   @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ShopConnection {
  id           String   @id @default(cuid())
  userId       String

  /// TikTok Shop ID (unique).
  shopId       String   @unique
  shopName     String

  /// Encrypted at rest (AES-256-GCM) via packages/db/src/crypto.ts
  accessToken  String
  refreshToken String

  expiresAt    DateTime
  scopes       String[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Product {
  id            String   @id @default(cuid())
  canonicalKey  String   @unique
  title         String
  imageUrl      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  snapshots     ProductSnapshot[]

  @@index([title])
}

/// 1 row per day per marketplace per product.
model ProductSnapshot {
  id          String          @id @default(cuid())
  productId   String
  marketplace MarketplaceCode
  day         DateTime

  currency    String?
  price       Decimal?        @db.Decimal(12, 2)
  sales       Int?
  rank        Int?
  views       Int?

  raw         Json?
  createdAt   DateTime        @default(now())

  product     Product         @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, marketplace, day])
  @@index([marketplace, day])
}

