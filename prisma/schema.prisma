// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id String @id @default(cuid())
  email String @unique
  name String?
  password String?
  role String
  createdAt DateTime @default(now())
  products Product[] @relation("SupplierProducts")
  affiliateProducts AffiliateProduct[]
  affiliateStore AffiliateStore?
  supplierOrders Order[] @relation("SupplierOrders")
  affiliateOrders Order[] @relation("AffiliateOrders")
  notifications Notification[]
  cart Cart?
}

model AffiliateStore {
  id String @id @default(cuid())
  userId String @unique
  slug String @unique
  user User @relation(fields: [userId], references: [id])
}

model Product {
  id String @id @default(cuid())
  supplierId String
  name String
  description String
  images String[] @default([])
  basePriceCents Int
  commissionRate Int
  stock Int @default(0)
  active Boolean @default(true)
  supplier User @relation("SupplierProducts", fields: [supplierId], references: [id])
  listings AffiliateProduct[]
  orders Order[]
}

model AffiliateProduct {
  id String @id @default(cuid())
  affiliateId String
  productId String
  sellingPriceCents Int
  active Boolean @default(true)
  affiliate User @relation(fields: [affiliateId], references: [id])
  product Product @relation(fields: [productId], references: [id])
  cartItems CartItem[]

  @@unique([affiliateId, productId])
}

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
}

model CartItem {
  id                 String           @id @default(cuid())
  cartId             String
  affiliateProductId String
  quantity           Int              @default(1)
  cart               Cart             @relation(fields: [cartId], references: [id], onDelete: Cascade)
  affiliateProduct   AffiliateProduct @relation(fields: [affiliateProductId], references: [id], onDelete: Cascade)

  @@unique([cartId, affiliateProductId])
}

model Order {
  id String @id @default(cuid())
  productId String
  affiliateProductId String
  supplierId String
  affiliateId String
  customerEmail String
  shippingAddress Json
  basePriceCents Int
  sellingPriceCents Int
  commissionCents Int
  marginCents Int
  affiliatePayoutCents Int
  status String @default("paid")
  stripeSessionId String @unique
  createdAt DateTime @default(now())
  product Product @relation(fields: [productId], references: [id])
  supplier User @relation("SupplierOrders", fields: [supplierId], references: [id])
  affiliate User @relation("AffiliateOrders", fields: [affiliateId], references: [id])
}

model Notification {
  id String @id @default(cuid())
  userId String
  type String
  message String
  orderId String?
  read Boolean @default(false)
  createdAt DateTime @default(now())
  user User @relation(fields: [userId], references: [id])
}
