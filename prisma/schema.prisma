// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled Neon host for runtime
  directUrl = env("DATABASE_URL_UNPOOLED") // direct host for migrate deploy (no -pooler)
}

model User {
  id                               String    @id @default(cuid())
  email                            String    @unique
  emailVerified                    DateTime?
  name                             String?
  image                            String?
  password                         String?
  role                             String    @default("CUSTOMER")
  createdAt                        DateTime  @default(now())
  videoQuota                       Int       @default(3)
  videoCount                       Int       @default(0) @map("videoUsed")
  isPro                            Boolean   @default(false)
  /**
   * Affisell+ supplier trust badge eligibility (role SUPPLIER only).
   */
  isVerifiedSupplier               Boolean   @default(false)
  verifiedAt                       DateTime?
  /**
   * Rolling 90-day quality metrics snapshot { rating, disputeRate, shippingSLA48h }.
   */
  supplierMetrics                  Json?
  /**
   * Trust ladder: NONE | SPARK | FORGE | ORBITAL (1M+ orders = ORBITAL blue badge).
   */
  supplierTrustTier                String    @default("NONE")
  supplierTrustTierAt              DateTime?
  /**
   * Cached successful paid orders count (recomputed by verify-suppliers cron).
   */
  supplierSuccessfulOrders         Int       @default(0)
  stripeCustomerId                 String?   @unique
  stripeSubscriptionId             String?   @unique
  /**
   * Stripe Connect Express/Standard account for marketplace seller payouts.
   */
  stripeAccountId                  String?   @unique
  /**
   * Set when Connect transfers capability is active (refresh-onboarding / successful split).
   */
  stripeOnboardedAt                DateTime?
  /**
   * Last known Stripe Connect capabilities snapshot (onboarding errors / refresh).
   */
  stripeCapabilities               Json?
  /**
   * Seller VAT number (invoicing; seller remains liable for VAT).
   */
  vatNumber                        String?
  /**
   * Default supplier → affiliate commission (bps) for new catalog rows when product rate unset.
   * 1100 = 11% of supplier wholesale offered to affiliates.
   */
  defaultSupplierCommissionRateBps Int?
  /**
   * Phase 1 legacy: overrides both catalog + auto-buy fee bps when set.
   */
  supplierFeeBps                   Int?
  /**
   * Phase 1: fee on supplier wholesale — catalogue natif (défaut 10 %).
   */
  supplierFeeBpsCatalog            Int?
  /**
   * Phase 1: fee on supplier wholesale — ligne auto-buy AE (défaut 17 %).
   */
  supplierFeeBpsAutoBuy            Int?
  /**
   * Phase 1: Affisell fee on affiliate earnings (bps), default 20 %.
   */
  affiliatePlatformFeeBps          Int?
  /**
   * CGU acceptance (`/cgu`).
   */
  cguAcceptedAt                    DateTime?
  cguVersion                       String?
  /**
   * CGS / CGA (role-specific) acceptance timestamp.
   */
  termsAcceptedAt                  DateTime?
  termsAcceptedVersion             String?
  /**
   * Privacy policy acceptance.
   */
  privacyAcceptedAt                DateTime?
  privacyAcceptedVersion           String?
  /**
   * Cookie preferences: `{ essential: true, analytics: boolean, marketing: boolean, updatedAt: ISO }`.
   */
  cookieConsent                    Json?
  proActivatedAt                   DateTime?

  accounts            Account[]
  sessions            Session[]
  passwordResetTokens PasswordResetToken[]

  /**
   * Agent Network — lien 1:1 quand candidature validée (role AGENT).
   */
  sourcingAgent SourcingAgent?

  products             Product[]          @relation("SupplierProducts")
  affiliateProducts    AffiliateProduct[]
  supplierOrders       Order[]            @relation("SupplierOrders")
  store                Store?
  affiliateOrders      Order[]            @relation("AffiliateOrders")
  notifications        Notification[]
  cart                 Cart?
  storeFollowRelations Follow[]           @relation("UserFollowsStore")
  searchHistory        SearchHistory[]
  wishlists            Wishlist[]
  pushSubscriptions    PushSubscription[]
  auctionBids          AuctionBid[]
  bookingWaitlist      BookingWaitlist[]

  /**
   * Supplier add-product: recent category picks JSON [{ leafId, path:[{id,name}] }] max 5
   */
  supplierRecentCategories Json @default("[]")

  supplierIntegrations SupplierIntegration[]

  /**
   * Chrome / Firefox extension import tokens (hashed secret).
   */
  supplierExtensionTokens SupplierExtensionToken[]

  /**
   * Optional blind-dropship API profile for this supplier user (parallel to native Affisell listings).
   */
  blindDropshipSupplier BlindDropshipSupplier?

  /**
   * Buyer-initiated returns (marketplace-style case flow).
   */
  orderReturnsRequested OrderReturn[] @relation("BuyerOrderReturns")

  /**
   * Store credit / cashback balance (EUR cents) from partner listings; spendable at checkout.
   */
  buyerRewardBalanceCents Int                    @default(0)
  buyerRewardLedger       BuyerRewardLedger[]
  /**
   * Marketplace orders where this user was the logged-in buyer (optional).
   */
  buyerMarketplaceOrders  Order[]                @relation("BuyerMarketplaceOrders")
  merchantPayoutLedger    MerchantPayoutLedger[]

  blindDropshipAffiliateOrders BlindDropshipOrder[] @relation("BlindDropshipAffiliateOrders")
  blindDropshipBuyerOrders     BlindDropshipOrder[] @relation("BlindDropshipBuyerOrders")

  buyerReviews  Review[]      @relation("BuyerReviews")
  reviewVotes   ReviewVote[]
  reviewReplies ReviewReply[] @relation("CreatorReviewReplies")

  tryOns    TryOn[]
  tryOnJobs TryOnJob[]

  /**
   * Invitations sent to onboard suppliers (affiliate → supplier collaboration).
   */
  affiliateSupplierInvitations AffiliateSupplierInvitation[] @relation("AffiliateSupplierInvites")
  /**
   * Set when this supplier registered via an affiliate invite link.
   */
  supplierInvitationFrom       AffiliateSupplierInvitation?  @relation("SupplierFromInvite")

  /**
   * Invitations sent to onboard affiliates (supplier → affiliate collaboration).
   */
  supplierAffiliateInvitations SupplierAffiliateInvitation[] @relation("SupplierAffiliateInvites")
  /**
   * Set when this affiliate registered via a supplier invite link.
   */
  affiliateInvitationFrom      SupplierAffiliateInvitation?  @relation("AffiliateFromSupplierInvite")

  /**
   * Swipe Feed — like / skip decisions on catalog products.
   */
  affiliateSwipes AffiliateSwipe[]

  sponsorCampaigns SponsorCampaign[] @relation("SponsorCampaignPayer")

  /**
   * KYC / legal onboarding for SUPPLIER & AFFILIATE (status + documents).
   */
  merchantLegalProfile MerchantLegalProfile?

  /**
   * Lightning Payout — supplier trust + Connect settlement profile.
   */
  supplierProfile SupplierProfile?

  /**
   * Lightning Payout — affiliate Connect settlement profile.
   */
  affiliateProfile AffiliateProfile?

  termsAcceptanceLogs TermsAcceptanceLog[]

  /**
   * CUSTOMER checkout account: INDIVIDUAL (particulier) or PROFESSIONAL (facturation pro).
   */
  buyerAccountType String?
}

/**
 * Preuve horodatée d'acceptation CGU / conditions (art. 1366 C. civ.).
 */
model TermsAcceptanceLog {
  id        String   @id @default(cuid())
  userId    String
  /// `cgu` | `conditions-fournisseur` | `conditions-affilie`
  type      String
  version   String
  ip        String
  userAgent String   @db.Text
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([createdAt])
}

/**
 * Merchant legal status + verification (supplier / affiliate signup).
 */
model MerchantLegalProfile {
  id                       String    @id @default(cuid())
  userId                   String    @unique
  user                     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /**
   * PARTICULIER | AUTO_ENTREPRENEUR | EI_PROFESSIONAL | COMPANY | ASSOCIATION | FOREIGN
   */
  legalStatus              String
  /**
   * PENDING_REVIEW | APPROVED | REJECTED | NEEDS_MORE_INFO
   */
  verificationStatus       String    @default("PENDING_REVIEW")
  legalEntityName          String?
  tradeName                String?
  siret                    String?
  vatNumber                String?
  rnaNumber                String?
  countryCode              String    @default("FR")
  submittedAt              DateTime  @default(now())
  reviewedAt               DateTime?
  rejectionReason          String?
  /**
   * Idempotent merchant KYC publish reminder (cron).
   */
  kycPublishReminderSentAt DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  documents MerchantLegalDocument[]

  @@index([verificationStatus])
  @@index([legalStatus])
}

model MerchantLegalDocument {
  id            String               @id @default(cuid())
  profileId     String
  profile       MerchantLegalProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  /**
   * IDENTITY_FRONT | IDENTITY_BACK | KBIS_OR_INSEE | SIRET_ATTESTATION | VAT_CERTIFICATE |
   * COMPANY_STATUTES | PROOF_OF_ADDRESS | FOREIGN_REGISTRATION | RNA_RECEIPT | ASSOCIATION_STATUTES
   */
  documentType  String
  fileUrl       String
  fileName      String?
  mimeType      String?
  fileSizeBytes Int?
  uploadedAt    DateTime             @default(now())

  @@unique([profileId, documentType])
  @@index([profileId])
}

/**
 * Supplier Lightning Payout — trust scoring and instant settlement eligibility.
 */
model SupplierProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  trustScore              Int      @default(50) // 0-100
  lightningEnabled        Boolean  @default(false)
  /** Admin bypass of trust-score gate for Lightning Payout (founder override). */
  lightningAdminOverride  Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

/**
 * Affiliate Lightning Payout — dedicated Connect account for commission transfers.
 */
model AffiliateProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

/**
 * Pre-signup document uploads (claimed on account creation, then deleted).
 */
model SignupDocumentDraft {
  id            String   @id @default(cuid())
  draftId       String
  documentType  String
  fileUrl       String
  fileName      String?
  mimeType      String?
  fileSizeBytes Int?
  expiresAt     DateTime
  createdAt     DateTime @default(now())

  @@unique([draftId, documentType])
  @@index([draftId])
  @@index([expiresAt])
}

/**
 * Contact / support tickets — persisted for admin terminal (email still sent via Resend).
 */
model SupportTicket {
  id         String    @id @default(cuid())
  ticketRef  String    @unique
  name       String
  email      String
  subject    String
  message    String    @db.Text
  /**
   * OPEN | IN_PROGRESS | RESOLVED | SPAM
   */
  status     String    @default("OPEN")
  adminNote  String?   @db.Text
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([status, createdAt])
  @@index([email])
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  entityType String
  entityId   String?
  actorId    String?
  payload    Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([action, createdAt])
}

/**
 * Saved connections for supplier catalog sync (Shopify, inbound webhook, …).
 */
model SupplierIntegration {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /**
   * Lowercase slug e.g. `shopify`, `webhook`.
   */
  platform        String
  /**
   * User-visible label; unique per user+platform.
   */
  name            String    @default("main")
  enabled         Boolean   @default(true)
  /**
   * Shopify: { shop, accessToken, apiVersion? }. Webhook: { webhookSecret }.
   */
  config          Json      @default("{}")
  lastSyncAt      DateTime?
  lastSyncError   String?
  lastSyncSummary Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([userId, platform, name])
  @@index([userId])
}

/**
 * Bearer token for the supplier browser extension (catalog import from product pages).
 */
model SupplierExtensionToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  label      String    @default("Browser")
  tokenHash  String    @unique
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
}

model Store {
  id                   String    @id @default(cuid())
  userId               String    @unique
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                 String
  slug                 String    @unique
  /**
   * Opaque ref (e.g. AFS-…) for supplier/support; never substitute for public store branding.
   */
  partnerListingCode   String    @unique
  logoUrl              String?
  /**
   * Optional Affisell AI–generated square profile image (shown in addition to or instead of logo where supported).
   */
  aiAvatarUrl          String?
  bannerUrl            String?
  description          String?
  customDomain         String?   @unique
  domainVerified       Boolean   @default(false)
  /**
   * Vercel project domain registration: registered | pending | active | failed | skipped
   */
  vercelDomainStatus   String?
  vercelDomainError    String?
  vercelDomainSyncedAt DateTime?
  /**
   * Public storefront branding: `{ "primary"?: "#hex", "accent"?: "#hex" }`.
   */
  storefrontTheme      Json?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  instagram              String?
  tiktok                 String?
  youtube                String?
  twitch                 String?
  facebook               String?
  twitter                String?
  followers              Json?
  showSocialsOnStore     Boolean   @default(true)
  /**
   * When false, affiliates do not see supplier net wholesale on order breakdowns.
   */
  showRevenueToAffiliate Boolean   @default(false)
  autoSyncFollowersDaily Boolean   @default(false)
  isLive                 Boolean   @default(false)
  livePlatform           String?
  liveUrl                String?
  lastSyncAt             DateTime?

  /**
   * Structured ship-from address (labels, returns instructions, partner comms).
   */
  shipFromAddress Json?
  /**
   * Return receiving address; when null, treat as same as `shipFromAddress` when displaying.
   */
  returnAddress   Json?

  communityPosts    CommunityPost[]
  followerRelations Follow[]        @relation("StoreFollowers")
}

enum AttributeValueType {
  TEXT
  NUMBER
  BOOLEAN
  SELECT_SINGLE
  SELECT_MULTI
  UNIT_VALUE
  TEXTAREA
}

enum CategoryTemplateType {
  TITLE
  DESC
}

model Category {
  id       String @id @default(cuid())
  /**
   * Google Product Taxonomy numeric id (fr-FR file); null for legacy rows.
   */
  googleId Int?   @unique
  /**
   * Not unique: leaf rows can share labels (e.g. "Clothing") under different parents.
   */
  name     String
  slug     String @unique
  icon     String @default("📦")
  order    Int    @default(0)

  parentId String?
  parent   Category?  @relation("CategoryToCategory", fields: [parentId], references: [id])
  /**
   * Nested browse nodes (same model — distinct from `tabularSubcategories` legacy table).
   */
  children Category[] @relation("CategoryToCategory")

  /**
   * Depth in tree (1 = root). Used for Google taxonomy import ordering.
   */
  level    Int     @default(1)
  fullPath String  @default("")
  isLeaf   Boolean @default(false)

  /**
   * Materialized ancestor id path for fast descendant queries (e.g. `cuid1.cuid2.cuid3`).
   */
  pathIds String?

  /**
   * SEO — optional browse meta.
   */
  metaTitle String?
  metaDesc  String? @db.Text

  /**
   * Grand comptoir: noms de specs côté catégorie feuille (ex. Marque, Taille).
   * @deprecated Prefer `CategoryAttribute` + global `Attribute` catalog.
   */
  specs String[] @default([])

  /**
   * Affisell platform fee on storefront sales in this category (basis points, 1000 = 10%).
   * Child categories inherit by walking `parentId` when unset (null); default 1000 at DB level.
   */
  affisellCommissionRateBps Int?

  /**
   * Default supplier → affiliate commission for products in this category (bps, 1100 = 11%).
   * Child categories inherit by walking `parentId` when unset.
   */
  supplierCommissionRateBps Int?

  products Product[]

  attributes CategoryAttribute[]
  templates  CategoryTemplate[]

  /**
   * Legacy per-department table (CSV/import); distinct from nested `children` above.
   */
  tabularSubcategories Subcategory[] @relation("CategoryTabularSubcategory")

  @@index([parentId, order])
  @@index([level])
  @@index([pathIds])
}

/**
 * Global reusable attribute definition (Couleur, Stockage, RAM…).
 */
model Attribute {
  id             String             @id @default(cuid())
  name           String
  slug           String             @unique
  type           AttributeValueType
  unit           String?
  validationJson Json?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  options            AttributeOption[]
  categoryAttributes CategoryAttribute[]
  variantValues      VariantAttributeValue[]

  @@index([type])
}

/**
 * Select / multi-select option rows for a global `Attribute`.
 */
model AttributeOption {
  id          String    @id @default(cuid())
  attributeId String
  attribute   Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  value       String
  slug        String
  hexColor    String?
  sortOrder   Int       @default(0)

  variantValues VariantAttributeValue[]

  @@unique([attributeId, slug])
  @@index([attributeId, sortOrder])
}

model CategoryAttribute {
  id         String   @id @default(cuid())
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  /**
   * When set, definition (type, unit, options) is resolved from global `Attribute`.
   * Legacy rows keep inline key/label/type until backfilled by migration script.
   */
  attributeId String?
  attribute   Attribute? @relation(fields: [attributeId], references: [id], onDelete: SetNull)

  key                  String
  label                String
  type                 String
  unit                 String?
  /**
   * @deprecated Prefer `AttributeOption` when `attributeId` is set. Kept for legacy rows.
   */
  options              String[] @default([])
  required             Boolean  @default(false)
  order                Int      @default(0)
  aiSuggest            Boolean  @default(true)
  showInFilter         Boolean  @default(true)
  /**
   * Drives SKU / variant matrix dimensions (Amazon-style).
   */
  isVariant            Boolean  @default(false)
  /**
   * null = inherit from `showInFilter`.
   */
  isFilterable         Boolean?
  appliesToDescendants Boolean  @default(false)
  /**
   * Optional constraints, e.g. `{"min": 64, "max": 1024}` or `{"pattern": "^[0-9]{13}$"}`.
   */
  validationRule       Json?
  /**
   * Show this field only when `dependsOnKey` equals `dependsOnValue` in the form state.
   */
  dependsOnKey         String?
  dependsOnValue       String?
  helpText             String?

  @@unique([categoryId, key])
  @@index([categoryId])
  @@index([attributeId])
  @@index([dependsOnKey])
}

/**
 * Title / description templates per category (Amazon-style prefill).
 */
model CategoryTemplate {
  id             String               @id @default(cuid())
  categoryId     String
  category       Category             @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  templateType   CategoryTemplateType
  templateString String               @db.Text

  @@unique([categoryId, templateType])
  @@index([categoryId])
}

model Subcategory {
  id         String    @id @default(cuid())
  name       String
  slug       String
  categoryId String
  category   Category  @relation("CategoryTabularSubcategory", fields: [categoryId], references: [id], onDelete: Cascade)
  products   Product[]

  @@unique([categoryId, slug])
}

model Product {
  id                            String             @id @default(cuid())
  /**
   * Internal Affisell SKU (AFF-00001).
   */
  affisellSku                   String?            @unique
  supplierId                    String
  name                          String
  description                   String
  /**
   * Marketplace “About this item” bullets (distinct from prose description).
   */
  descriptionBullets            String[]           @default([])
  /**
   * Extra lifestyle / detail images shown under the long description (not gallery heroes).
   */
  descriptionIllustrationImages String[]           @default([])
  /**
   * HTTPS links: YouTube, Vimeo, or direct `.mp4` — shown under the description.
   */
  descriptionIllustrationVideos String[]           @default([])
  createdAt                     DateTime           @default(now())
  updatedAt                     DateTime           @default(now()) @updatedAt
  images                        String[]           @default([])
  colorImages                   Json?
  /**
   * @deprecated Legacy department labels — use `categoryId` + `category.fullPath`.
   */
  categories                    String[]           @default([])
  colors                        String[]           @default([])
  variants                      Json?
  /**
   * Amazon-style parent listing: sellable SKUs live in `ProductVariant` children.
   */
  isVariantParent               Boolean            @default(false)
  /**
   * When true, SKU lines live in `ProductVariant` (supplier/public price per row).
   */
  hasVariants                   Boolean            @default(false)
  /**
   * Supplier-defined SKU columns: [{ key, label, type, required, options? }]
   */
  customColumns                 Json?
  productVariants               ProductVariant[]
  tags                          String[]           @default([])
  basePriceCents                Int
  compareAt                     Decimal?
  commissionRate                Int
  /**
   * Supplier → affiliate commission in basis points (1000 = 10% of supplier price).
   */
  supplierCommissionRateBps     Int?
  /**
   * PHYSICAL: affiliate commission % max 99; SOFTWARE | SUBSCRIPTION | SERVICE | EXPERIENCE allow up to 100.
   */
  listingKind                   String             @default("PHYSICAL")
  /**
   * Instant digital delivery (formations, software): HTTPS access URL for buyers.
   * Supports {{orderId}}, {{token}}, {{email}} placeholders at fulfillment.
   */
  digitalAccessUrl              String?
  digitalAccessInstructions     String?            @db.Text
  /**
   * When true (default), buyers receive access automatically after payment.
   */
  digitalInstantDelivery        Boolean            @default(true)
  /**
   * Default session length for SERVICE / EXPERIENCE listings (minutes).
   */
  bookingDurationMinutes        Int?
  /**
   * Buyer may cancel free until this many hours before slot start.
   */
  bookingCancellationHours      Int                @default(24)
  /**
   * Venue label shown on booking pass (salon, cinema, museum…).
   */
  bookingVenueLabel             String?
  /**
   * When true, booking is confirmed instantly after payment (Phase 1+).
   */
  bookingInstantConfirm         Boolean            @default(true)
  /**
   * Cinema seat map preset — see lib/booking/seat-layout.ts (EXPERIENCE only).
   */
  bookingSeatLayout             Json?
  bookingSlots                  BookingSlot[]
  bookingWaitlist               BookingWaitlist[]
  agentMissions                 AgentMission[]
  chinaBuyRouteLogs             ChinaBuyRouteLog[]
  stock                         Int                @default(0)
  active                        Boolean            @default(true)
  /**
   * In-progress listing; always kept inactive until published.
   */
  isDraft                       Boolean            @default(false)

  /**
   * Normalized taxonomy (optional — legacy rows still match via `categories[]` in counts).
   */
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  /**
   * Optional Affisell platform fee override (bps). Takes precedence over category rate.
   * Distinct from `commissionRate` (supplier → affiliate margin share %).
   */
  affisellCommissionRateOverrideBps Int?

  subcategoryId String?
  subcategory   Subcategory? @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)

  /**
   * Marketplace filter: minimalist, vintage, etc.
   */
  style String?

  /**
   * Filter bucket: standard | free | prime | same-day | next-day — see counts API
   */
  shippingType String @default("standard")

  /**
   * Processing / handling lag (supplier → ship), used beside delivery windows
   */
  handlingDays Int @default(1)

  isOnSale         Boolean @default(false)
  isNewArrival     Boolean @default(false)
  isBestSeller     Boolean @default(false)
  isRefurbished    Boolean @default(false)
  hasCoupon        Boolean @default(false)
  isEcoFriendly    Boolean @default(false)
  /**
   * STANDARD | REFURBISHED | SECOND_HAND | WHOLESALE_ONLY | DONATION
   */
  offerMode        String  @default("STANDARD")
  /**
   * Minimum units per order (MOQ) — enforced for WHOLESALE_ONLY.
   */
  minOrderQuantity Int     @default(1)

  shippingCountry       String?
  warehouseType         String?
  warehouseCity         String?
  /**
   * ISO-2 destination countries the supplier delivers to.
   * Empty = legacy heuristic (warehouse zone). `WORLDWIDE` = all checkout countries.
   */
  deliveryCountryCodes  String[] @default([])
  processingTime        Int      @default(1)
  deliveryMin           Int      @default(2)
  deliveryMax           Int      @default(5)
  shippingMethods       String[] @default([])
  freeShippingThreshold Decimal?
  shippingCost          Decimal  @default(0)

  /**
   * Marketplace display / API (e.g. "EU", "FR"). Distinct from `shippingCountry` filter fields.
   */
  shipsFrom              String?
  deliveryDays           Int?
  freeShipping           Boolean              @default(false)
  /**
   * Supplier opt-in: product may appear on `/luxe` when listed by an affiliate.
   */
  isLuxury               Boolean              @default(false)
  /**
   * Display source label (e.g. "seed"); API may expose as `supplier` string.
   */
  supplierTag            String?
  /**
   * AliExpress Open API product id (dropshipping import).
   */
  aliexpressProductId    String?
  /**
   * Import channel, e.g. `aliexpress`.
   */
  importSource           String?
  /**
   * Auto-Order Engine: route paid lines to external suppliers without buyer treasury advance.
   */
  autoFulfill            Boolean              @default(true)
  fulfillmentChannel     SupplierChannelType?
  sourceProductId        String?
  sourceSkuId            String?
  sourceUrl              String?
  /**
   * China buying agent (Superbuy, Anovabuy, …) chosen at import.
   */
  chinaBuyingAgentId     String?
  /**
   * Source marketplace (1688, Taobao, …).
   */
  chinaPlatform          String?
  /**
   * Manual AE variant picker map for browser auto-buy, e.g. { "Color": "Black", "Size": "M" }.
   */
  variantMapping         Json?
  /**
   * Phase 1 AE auto-buy enabled (admin); synced with SupplierLink when present.
   */
  autoBuyEnabled         Boolean              @default(false)
  fulfillmentDelayHours  Int                  @default(0)
  /**
   * Minimum margin in basis points (1500 = 15%).
   */
  minMarginBps           Int                  @default(1500)
  /**
   * Blind dropship: partner SKU + wholesale cost (cents) sent to supplier APIs only — never shopper/affiliate price.
   * Null when the product is only sold through native Affisell fulfillment.
   */
  supplierSku            String?
  supplierWholesaleCents Int?
  videoAdUrl             String?
  videoAdPrompt          String?              @db.Text
  videoAdStatus          String?              @default("none") // none | generating | ready | failed
  videoGenerationJobs    VideoGenerationJob[]
  videos                 ProductVideo[]
  reviewCount            Int                  @default(0)
  averageRating          Float                @default(0)
  reviewSentiment        String               @default("neutral")
  /**
   * Published buyer UGC rows with at least one image or video in `media`.
   */
  ugcCount               Int                  @default(0)

  /**
   * AI virtual try-on (apparel): supplier enables + uploads transparent PNG flat-lay.
   */
  tryOnEnabled    Boolean @default(false)
  tryOnGarmentUrl String?
  /**
   * Medusa v2 product handle — sync target for admin try-on toggles.
   */
  medusaHandle    String? @unique
  /**
   * Medusa v2 variant id — cached for order sync (backfill:variants).
   */
  medusaVariantId String?

  supplier                User                     @relation("SupplierProducts", fields: [supplierId], references: [id])
  tryOns                  TryOn[]
  tryOnJobs               TryOnJob[]
  affiliateProducts       AffiliateProduct[]
  affiliateSwipes         AffiliateSwipe[]
  sponsorCampaigns        SponsorCampaign[]
  attributes              ProductAttribute[]
  orders                  Order[]
  blindDropshipOrderItems BlindDropshipOrderItem[]
  communityPosts          CommunityPost[]
  wishlists               Wishlist[]
  guestWishlists          GuestWishlist[]
  auctions                Auction[]
  reviews                 Review[]
  /**
   * AI category suggestions pending manual review (see `ProductReview` model).
   */
  productReviews          ProductReview[]
  /**
   * AliExpress auto-buy source (1:1).
   */
  supplierLink            SupplierLink?

  @@index([categoryId])
  @@index([aliexpressProductId])
  @@index([supplierId, isDraft])
  @@index([style])
  @@index([shippingType])
  @@index([basePriceCents])
  @@index([isOnSale])
  @@index([isLuxury])
  @@index([offerMode])
  @@index([createdAt])
  @@index([listingKind])
}

/**
 * Time-bound inventory for SERVICE / EXPERIENCE listings (cinéma, coiffeur, musée…).
 */
model BookingSlot {
  id                 String            @id @default(cuid())
  productId          String
  product            Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  startsAt           DateTime
  endsAt             DateTime
  capacity           Int
  bookedCount        Int               @default(0)
  /**
   * Seats reserved during Stripe checkout (released on pay, expiry, or cancel).
   */
  heldCount          Int               @default(0)
  priceCentsOverride Int?
  label              String?
  /**
   * OPEN | SOLD_OUT | CANCELLED
   */
  status             String            @default("OPEN")
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  orders             Order[]
  seats              BookingSeat[]
  waitlist           BookingWaitlist[]

  @@index([productId, startsAt])
  @@index([status, startsAt])
}

/**
 * Buyer waitlist when a slot is full — notified when seats free up.
 */
model BookingWaitlist {
  id            String      @id @default(cuid())
  slotId        String
  slot          BookingSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  productId     String
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  email         String
  userId        String?
  user          User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  qty           Int         @default(1)
  phone         String?
  notifiedAt    DateTime?
  smsNotifiedAt DateTime?
  createdAt     DateTime    @default(now())

  @@unique([slotId, email])
  @@index([slotId, notifiedAt, createdAt])
  @@index([productId])
}

/**
 * Nominative cinema seats (A12, B4…) — EXPERIENCE slots with capacity > 1.
 */
model BookingSeat {
  id            String      @id @default(cuid())
  slotId        String
  slot          BookingSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  label         String
  rowIndex      Int
  colIndex      Int
  /**
   * OPEN | HELD | BOOKED
   */
  status        String      @default("OPEN")
  orderId       String?
  order         Order?      @relation(fields: [orderId], references: [id], onDelete: SetNull)
  holdExpiresAt DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([slotId, label])
  @@index([slotId, status])
  @@index([orderId])
}

model ProductVariant {
  id                  String   @id @default(cuid())
  productId           String
  product             Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku                 String?
  /**
   * AE attribute map for this row, e.g. { "Color": "Black", "Size": "M" }.
   */
  attributes          Json?
  /**
   * AliExpress SKU id when known (manual).
   */
  supplierSku         String?
  color               String?
  size                String?
  /**
   * Wholesale HT cents (preferred for AE auto-buy when set).
   */
  wholesalePriceCents Int?
  /**
   * Prix payé au fournisseur (wholesale).
   */
  supplierPrice       Decimal  @db.Decimal(10, 2)
  /**
   * Prix affiché client (selling).
   */
  publicPrice         Decimal  @db.Decimal(10, 2)
  stock               Int      @default(0)
  weightGrams         Int?
  processingDays      Int?     @default(2)
  ean                 String?  @unique
  originCountry       String?  @default("CN")
  warehouseCode       String?
  purchasePriceHT     Decimal? @db.Decimal(10, 2)
  moq                 Int?     @default(1)
  videoUrl            String?
  /**
   * Per-SKU values for `Product.customColumns` keys
   */
  customData          Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  supplierLinkVariants SupplierLinkVariant[]
  attributeValues      VariantAttributeValue[]

  @@unique([productId, color, size, sku])
  @@index([productId])
}

/**
 * Typed EAV values per sellable variant (colour, storage, RAM…).
 */
model VariantAttributeValue {
  id           String           @id @default(cuid())
  variantId    String
  variant      ProductVariant   @relation(fields: [variantId], references: [id], onDelete: Cascade)
  attributeId  String
  attribute    Attribute        @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  valueText    String?
  valueNumber  Decimal?         @db.Decimal(18, 4)
  valueBoolean Boolean?
  optionId     String?
  option       AttributeOption? @relation(fields: [optionId], references: [id], onDelete: SetNull)

  @@unique([variantId, attributeId])
  @@index([attributeId])
  @@index([optionId])
}

model ProductVideo {
  id        String   @id @default(cuid())
  productId String   @unique
  videoUrl  String
  jobId     String
  prompt    String
  style     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

/**
 * AI / ops queue: suggested taxonomy row for a product (not shopper star reviews — those use `Review`).
 */
model ProductReview {
  id                String   @id @default(cuid())
  productId         String
  product           Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  suggestedCategory String
  confidence        Float
  reason            String   @db.Text
  createdAt         DateTime @default(now())

  @@index([productId])
  @@index([createdAt])
}

model ProductAttribute {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  key   String
  value String
  label String

  @@unique([productId, key])
  @@index([productId])
  @@index([key, value])
}

enum ReviewStatus {
  PENDING
  AI_FLAGGED
  PUBLISHED
  REJECTED
}

enum VoteType {
  HELPFUL
  UNHELPFUL
}

/**
 * Shopper & imported catalog reviews (Trust Engine). Legacy imports use `author` + `images`;
 * buyer submissions use `userId`, `orderId`, and `media` JSON UGC payloads.
 */
model Review {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  userId  String?
  user    User?   @relation("BuyerReviews", fields: [userId], references: [id], onDelete: SetNull)
  orderId String? @unique
  order   Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)

  rating Int
  title  String? @db.VarChar(120)
  body   String  @map("text") @db.Text

  /**
   * Legacy supplier import display name when `userId` is null.
   */
  author  String?
  country String?
  date    DateTime?
  variant String?
  images  String[]  @default([])

  /**
   * UGC payloads: [{ type: "image"|"video", url, blurhash?, width?, height?, duration?, muxPlaybackId? }]
   */
  media Json @default("[]")

  verified  Boolean @default(true)
  aiScore   Float?
  sentiment String? @default("neutral")

  helpfulCount Int @default(0) @map("helpful_count")
  viewCount    Int @default(0)

  status         ReviewStatus @default(PUBLISHED)
  moderationNote String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?

  votes ReviewVote[]
  reply ReviewReply?

  @@index([productId, status, publishedAt(sort: Desc)])
  @@index([rating, status])
  @@index([productId])
}

model ReviewVote {
  id        String   @id @default(cuid())
  reviewId  String
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      VoteType
  createdAt DateTime @default(now())

  @@unique([reviewId, userId])
  @@index([reviewId])
}

/**
 * Public creator / affiliate reply on a published review.
 */
model ReviewReply {
  id        String   @id @default(cuid())
  reviewId  String   @unique
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("CreatorReviewReplies", fields: [userId], references: [id], onDelete: Cascade)
  body      String   @db.Text
  createdAt DateTime @default(now())
}

model Wishlist {
  id                 String   @id @default(cuid())
  userId             String
  productId          String
  /**
   * Optional target alert threshold chosen by shopper (in cents).
   */
  targetPriceCents   Int?
  /**
   * Last daily seen price, used for "depuis hier" drop computation.
   */
  previousPriceCents Int?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId, updatedAt])
  @@index([productId, updatedAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  /** Web Push endpoint URL (unique per browser install). */
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/**
 * Anonymous buyer saves (likes) before account creation; merged into Wishlist on sign-in.
 */
model GuestWishlist {
  id        String   @id @default(cuid())
  guestId   String
  productId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([guestId, productId])
  @@index([productId])
  @@index([guestId, updatedAt])
}

enum AuctionStatus {
  SCHEDULED
  LIVE
  ENDED
  CANCELLED
}

/**
 * Time-boxed product auction on the Affisell Arena.
 */
model Auction {
  id                String        @id @default(cuid())
  productId         String
  listingId         String?
  title             String
  imageUrl          String?
  startPriceCents   Int
  reservePriceCents Int?
  currentBidCents   Int           @default(0)
  bidCount          Int           @default(0)
  startsAt          DateTime
  endsAt            DateTime
  status            AuctionStatus @default(LIVE)
  winnerUserId      String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  product Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  bids    AuctionBid[]

  @@index([status, endsAt])
  @@index([productId])
  @@index([listingId])
}

model AuctionBid {
  id          String   @id @default(cuid())
  auctionId   String
  userId      String
  amountCents Int
  createdAt   DateTime @default(now())

  auction Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([auctionId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
}

model SearchHistory {
  id        String   @id @default(cuid())
  userId    String?
  sessionId String?
  query     String
  productId String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([sessionId, createdAt])
}

/**
 * Homepage carousel analytics (view / hover / add-to-cart).
 */
model AffisellTrackEvent {
  id         String   @id @default(cuid())
  eventType  String
  productId  String?
  sessionId  String?
  userId     String?
  durationMs Int?
  createdAt  DateTime @default(now())

  @@index([productId, createdAt])
  @@index([eventType, createdAt])
  @@index([sessionId, createdAt])
}

model CommunityPost {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  content   String
  images    String[] @default([])
  /**
   * Short-form clip URL (mp4/webm) for Affisell Pulse feed.
   */
  videoUrl  String?
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  likes     Int      @default(0)
  views     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([views])
}

model Follow {
  id        String   @id @default(cuid())
  userId    String
  storeId   String
  user      User     @relation("UserFollowsStore", fields: [userId], references: [id], onDelete: Cascade)
  store     Store    @relation("StoreFollowers", fields: [storeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, storeId])
}

model AffiliateProduct {
  id          String     @id @default(cuid())
  affiliateId String
  productId   String
  affiliate   User       @relation(fields: [affiliateId], references: [id])
  product     Product    @relation(fields: [productId], references: [id])
  cartItems   CartItem[]
  orders      Order[]

  sellingPriceCents Int
  /**
   * Affiliate markup above supplier price (HT, per unit). 0 = derive from selling − base at checkout.
   */
  marginCents       Int @default(0)

  customTitle       String?
  customDescription String?
  customImages      String[] @default([])

  customSlug     String?
  seoTitle       String?
  seoDescription String?
  collections    String[] @default([])

  /**
   * Affisell Luxe window: only `LUXE` or `COLLECTION` (+ active `LuxuryCollection`) appear on `/luxe`.
   */
  luxuryTier         String            @default("NONE")
  luxuryCollectionId String?
  luxuryCollection   LuxuryCollection? @relation(fields: [luxuryCollectionId], references: [id], onDelete: SetNull)

  isListed        Boolean @default(true)
  isFeatured      Boolean @default(false)
  /**
   * Affiliate opt-in — only eligible listings are seeded into `/auctions`.
   */
  auctionEligible Boolean @default(false)
  position        Int     @default(0)

  clicks      Int @default(0)
  conversions Int @default(0)

  /**
   * Shopper-facing reward funded from the affiliate margin on this listing.
   * NONE — no offer; CASHBACK — % of purchase as cashback wording; BONUS — store bonus wording.
   */
  buyerRewardKind    String @default("NONE")
  /**
   * 0 when kind is NONE; otherwise 1–50 (% of line total), capped by available margin on save.
   */
  buyerRewardPercent Int    @default(0)

  /**
   * Optional PDP default: must match `Product.colors[]` when set.
   */
  promotedColor       String?
  /**
   * Optional PDP default: must match `Product.variants.size[]` when set.
   */
  promotedSize        String?
  /**
   * Subset of supplier variant keys shown on this affiliate storefront (empty = all).
   * Keys match `ProductVariantLine.name` or color-only labels from the supplier catalog.
   */
  promotedVariantKeys String[] @default([])

  /**
   * Per-variant affiliate prices keyed by variant label (same keys as promotedVariantKeys).
   * Example: { "12 Go de RAM / 256 Go de SSD": { "sellingPriceCents": 40250, "marginCents": 11151 } }
   */
  variantPricing Json?

  /**
   * When true, daily cron nudges per-variant `variantPricing` ±5% (idempotent per UTC day).
   */
  pricingAutoAdjust         Boolean   @default(false)
  pricingAutoAdjustLastRun DateTime?

  /**
   * Set when supplier wholesale rises or affiliate price falls below cost — review margins in listing builder.
   */
  marginReviewNeeded       Boolean   @default(false)
  marginReviewAt           DateTime?
  marginReviewVariantKeys  String[]  @default([])
  /** Last wholesale snapshot hash we notified for (idempotent alerts). */
  marginReviewAlertHash    String?

  /**
   * When true, show supplier warranty badge on storefront cards (requires warranty on SKUs).
   */
  showWarranty Boolean @default(false)

  blindDropshipOrderItems BlindDropshipOrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  sponsorCampaigns SponsorCampaign[]

  @@unique([affiliateId, productId])
  @@unique([affiliateId, customSlug])
  @@index([luxuryTier, isListed])
}

/**
 * Paid product placement — supplier or affiliate funds visibility via % of catalog HT (`basePriceCents`).
 */
model SponsorCampaign {
  id                      String    @id @default(cuid())
  payerUserId             String
  payerRole               String
  productId               String
  affiliateProductId      String?
  sponsorRateBps          Int
  htCentsSnapshot         Int
  feeCents                Int
  durationDays            Int
  placement               String
  status                  String    @default("PENDING_PAYMENT")
  boostScore              Int       @default(0)
  setsListingFeatured     Boolean   @default(false)
  startsAt                DateTime?
  endsAt                  DateTime?
  stripeCheckoutSessionId String?   @unique
  stripePaymentIntentId   String?   @unique
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  payer            User              @relation("SponsorCampaignPayer", fields: [payerUserId], references: [id], onDelete: Cascade)
  product          Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  affiliateProduct AffiliateProduct? @relation(fields: [affiliateProductId], references: [id], onDelete: SetNull)

  @@index([status, endsAt])
  @@index([affiliateProductId, status])
  @@index([productId, status, payerRole])
}

/**
 * Curated luxury collection — listings must have `luxuryTier = COLLECTION` + this id.
 */
model LuxuryCollection {
  id            String   @id @default(cuid())
  slug          String   @unique
  name          String
  tagline       String?
  coverImageUrl String?
  sortOrder     Int      @default(0)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  listings AffiliateProduct[]

  @@index([active, sortOrder])
}

/**
 * Affiliate Swipe Feed — records like / skip on catalog discovery cards.
 * Skip hides the product from future feed loads; like is recorded when a listing is created.
 */
model AffiliateSwipe {
  id          String   @id @default(cuid())
  affiliateId String
  affiliate   User     @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  /**
   * `like` | `skip`
   */
  action      String
  createdAt   DateTime @default(now())

  @@unique([affiliateId, productId])
  @@index([affiliateId, action])
  @@index([affiliateId, createdAt])
}

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
}

model CartItem {
  id                 String           @id @default(cuid())
  cartId             String
  affiliateProductId String
  quantity           Int              @default(1)
  /**
   * Normalized `c:…|s:…` — empty string when no variant picked.
   */
  variantSignature   String           @default("")
  selectedColor      String?
  selectedSize       String?
  cart               Cart             @relation(fields: [cartId], references: [id], onDelete: Cascade)
  affiliateProduct   AffiliateProduct @relation(fields: [affiliateProductId], references: [id], onDelete: Cascade)

  @@unique([cartId, affiliateProductId, variantSignature])
}

/**
 * Idempotent ledger for buyer store credit (earn on paid orders, redeem at checkout).
 */
model BuyerRewardLedger {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /**
   * EARNED | REDEEMED | REVERSAL (clawback on refund)
   */
  type            String
  amountCents     Int
  idempotencyKey  String   @unique
  stripeSessionId String?
  orderId         String?
  order           Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now())

  @@index([userId, createdAt])
  @@index([orderId])
}

enum OrderPaymentSettlementStatus {
  PENDING
  PAID
  /**
   * Connect transfer completed (seller paid out).
   */
  SETTLED
  PARTIALLY_REFUNDED
  REFUNDED
  /**
   * Buyer refunded but Connect transfer reversal failed or unverified — ledger clawback blocked.
   */
  REFUND_PENDING_CLAWBACK
  FAILED
  CANCELLED
}

enum TransferReversalStatus {
  SUCCESS
  FAILED
  PARTIAL
}

enum TransferRole {
  SUPPLIER
  AFFILIATE
}

enum TransferStatus {
  PENDING
  SUCCESS
  FAILED
}

enum SplitStatus {
  PENDING
  PARTIAL
  SUCCESS
  FAILED
}

model Order {
  id                               String                       @id @default(cuid())
  productId                        String
  affiliateProductId               String
  supplierId                       String
  affiliateId                      String
  /**
   * Logged-in buyer when checkout carried `buyerUserId` metadata (optional).
   */
  buyerUserId                      String?
  /**
   * Checkout UI locale snapshot for transactional emails (en, fr, de, …).
   */
  buyerLocale                      String?                      @db.VarChar(8)
  /**
   * Snapshot of product.listingKind at checkout (PHYSICAL | SOFTWARE | SUBSCRIPTION | SERVICE | EXPERIENCE).
   */
  listingKindSnapshot              String?
  /**
   * Resolved buyer access URL after instant digital fulfillment.
   */
  digitalAccessUrl                 String?
  digitalAccessInstructions        String?                      @db.Text
  digitalAccessToken               String?                      @unique
  digitalDeliveredAt               DateTime?
  /**
   * Reserved booking slot (Phase 1 checkout).
   */
  bookingSlotId                    String?
  bookingSlot                      BookingSlot?                 @relation(fields: [bookingSlotId], references: [id], onDelete: SetNull)
  /**
   * Frozen slot + policy at confirmation — see lib/booking/snapshot.ts
   */
  bookingSnapshot                  Json?
  bookingToken                     String?                      @unique
  bookingConfirmedAt               DateTime?
  /**
   * PENDING checkout hold expiry — see lib/booking/slot-hold.ts
   */
  bookingHoldExpiresAt             DateTime?
  bookingCancelledAt               DateTime?
  /**
   * Supplier QR / manual check-in at venue (Phase 4).
   */
  bookingCheckedInAt               DateTime?
  /**
   * Idempotent J-1 (~24h) booking reminder email.
   */
  bookingReminderDaySentAt         DateTime?
  /**
   * Idempotent H-2 (~2h) booking reminder email.
   */
  bookingReminderHourSentAt        DateTime?
  /**
   * Idempotent H-2 (~2h) booking reminder SMS (Twilio).
   */
  bookingReminderHourSmsSentAt     DateTime?
  /**
   * Idempotent supplier instant alert email on pass confirmation.
   */
  bookingSupplierAlertSentAt       DateTime?
  /**
   * Idempotent supplier J-0 digest email inclusion.
   */
  bookingSupplierDigestSentAt      DateTime?
  /**
   * Idempotent supplier in-app alert on marketplace checkout paid.
   */
  merchantSupplierInboxNotifiedAt  DateTime?
  /**
   * Idempotent affiliate in-app alert on marketplace checkout paid.
   */
  merchantAffiliateInboxNotifiedAt DateTime?
  /**
   * Idempotent supplier email alert on marketplace checkout paid.
   */
  merchantSupplierEmailSentAt      DateTime?
  /**
   * Idempotent affiliate email alert on marketplace checkout paid.
   */
  merchantAffiliateEmailSentAt     DateTime?
  bookingSeats                     BookingSeat[]
  buyer                            User?                        @relation("BuyerMarketplaceOrders", fields: [buyerUserId], references: [id], onDelete: SetNull)
  customerEmail                    String
  /**
   * E.164 from Stripe Checkout phone collection — booking SMS H-2.
   */
  customerPhone                    String?
  shippingAddress                  Json
  /**
   * Line quantity for this order row (multi-item checkout uses one row per SKU).
   */
  quantity                         Int                          @default(1)
  /**
   * Shoppers’ variant choice at checkout, e.g. "Purple · M" — optional.
   */
  variantLabel                     String?
  /**
   * Hero image for the chosen color at checkout (snapshot for fulfillment & alerts).
   */
  variantImageUrl                  String?
  basePriceCents                   Int
  sellingPriceCents                Int
  commissionCents                  Int
  marginCents                      Int
  affiliatePayoutCents             Int
  /**
   * Affisell marketplace fee (default 10% of line total paid).
   */
  affisellFeeCents                 Int                          @default(0)
  /**
   * Phase 1: platform fee on supplier wholesale (AE/catalog HT).
   */
  supplierFeeCents                 Int                          @default(0)
  /**
   * Phase 1: platform fee on affiliate earnings (commission + markup).
   */
  affiliateFeeCents                Int                          @default(0)
  /**
   * Snapshot AE purchase price HT (centimes) at checkout when SupplierLink exists.
   */
  aeWholesaleCents                 Int?
  /**
   * Auto-buy escrow: HT reserved on platform to pay supplier upstream (AE/CJ/…).
   * Null for native catalogue shipment.
   */
  upstreamCogsCents                Int?
  /**
   * Supplier Connect transfer snapshot (= supplierPayoutCents at checkout).
   */
  supplierMarginCents              Int?
  /**
   * Frozen at payment: true = Affisell AE auto-buy (17 % fee base on AE wholesale when set).
   * false = native supplier catalogue shipment (10 % on catalog wholesale).
   */
  usesAffisellAutoBuy              Boolean                      @default(false)
  /**
   * Affiliate markup kept above supplier commission offer (`margin − affiliate payout`).
   */
  affiliateMarginRetainedCents     Int                          @default(0)
  /**
   * Marketplace line: paid → preparing (seller packing + buyer notified) → shipped · refunded …
   */
  status                           String                       @default("paid")
  /**
   * Set when seller confirms they received / are packing; triggers buyer-visible “preparing” state.
   */
  supplierPreparingAt              DateTime?
  trackingCarrier                  String?
  trackingNumber                   String?
  /**
   * Set when tracking is validated — supplier cannot replace carrier/number after this.
   */
  trackingLockedAt                 DateTime?
  trackingVerifiedBy               String?
  shippedAt                        DateTime?
  /**
   * Carrier / supplier marked shipped — start of delivery & payout timers.
   */
  deliveredAt                      DateTime?
  /**
   * Attestation source for deliveredAt (aftership_webhook | digital_instant | booking_confirmed | legacy).
   */
  deliveredAtSource                String?
  /**
   * Buyer confirmed receipt, or auto after 10d silence.
   */
  deliveryConfirmedAt              DateTime?
  deliveryConfirmedBy              String?
  /**
   * When supplier + affiliate payouts may run (confirm+7d or auto at delivered+10d).
   */
  payoutEligibleAt                 DateTime?
  supplierPayoutAt                 DateTime?
  affiliatePayoutAt                DateTime?
  /**
   * Lightning Payout — Stripe transfer ids [supplierTransferId, affiliateTransferId].
   */
  payoutTransferIds                Json?
  /**
   * PENDING | PROCESSING | PAID | FAILED
   */
  payoutStatus                     String                       @default("PENDING")
  stripeSessionId                  String                       @unique
  /**
   * Medusa v2 order id (admin sync from Affisell Stripe checkout).
   */
  medusaOrderId                    String?                      @unique
  stripePaymentIntentId            String?                      @unique
  stripeInvoiceId                  String?                      @unique
  stripeChargeId                   String?                      @unique
  stripeTransferId                 String?                      @unique
  stripeCustomerId                 String?
  /**
   * Line HT (products) — commission 12% base, excludes tax.
   */
  subtotalCents                    Int?
  /**
   * Shipping HT (excl. tax).
   */
  shippingCents                    Int                          @default(0)
  /**
   * VAT collected on checkout (Stripe Tax; seller liable).
   */
  taxCents                         Int                          @default(0)
  taxCountry                       String?
  taxRate                          Decimal?                     @db.Decimal(5, 4)
  /**
   * Total paid by buyer (line TTC).
   */
  totalCents                       Int?
  platformCommissionRate           Decimal                      @default(0.12) @db.Decimal(5, 4)
  /**
   * Affisell platform fee (12% of subtotalCents). Distinct from affiliate `commissionCents`.
   */
  platformCommissionCents          Int                          @default(0)
  stripeFeesCents                  Int                          @default(0)
  /**
   * Net transferred to supplier via Stripe Connect.
   */
  sellerPayoutCents                Int                          @default(0)
  /**
   * Three-way split — supplier wholesale (HT).
   */
  supplierPriceCents               Int                          @default(0)
  supplierCommissionRateBps        Int                          @default(1000)
  /**
   * Affiliate markup above supplier price (HT).
   */
  affiliateMarginCents             Int                          @default(0)
  affisellCommissionRateBps        Int                          @default(1200)
  /**
   * Connect payout to supplier (three-way split).
   */
  supplierPayoutCents              Int                          @default(0)
  /**
   * Snapshot of affiliate Connect account at settlement.
   */
  affiliateStripeAccountId         String?
  currency                         String                       @default("EUR")
  paymentSettlementStatus          OrderPaymentSettlementStatus @default(PENDING)
  /**
   * Connect three-way split aggregate (TransferAttempt rows).
   */
  splitStatus                      SplitStatus                  @default(PENDING)
  createdAt                        DateTime                     @default(now())
  updatedAt                        DateTime                     @updatedAt
  product                          Product                      @relation(fields: [productId], references: [id])
  affiliateProduct                 AffiliateProduct             @relation(fields: [affiliateProductId], references: [id])
  supplier                         User                         @relation("SupplierOrders", fields: [supplierId], references: [id])
  affiliate                        User                         @relation("AffiliateOrders", fields: [affiliateId], references: [id])
  returns                          OrderReturn[]
  buyerRewardLedgerEntries         BuyerRewardLedger[]
  merchantPayoutLedger             MerchantPayoutLedger[]
  buyerReview                      Review?
  reviewReminderSentAt             DateTime?
  /**
   * Idempotent guard for cancelled/refunded buyer email (Resend).
   */
  cancelledEmailSentAt             DateTime?
  /**
   * Idempotent guard for payment-failed / update-card email (Stripe Billing Portal).
   */
  paymentFailedEmailSentAt         DateTime?
  /**
   * Universal Auto-Order Engine — aggregate fulfillment across supplier channels.
   */
  fulfillmentStatus                FulfillmentStatus            @default(PENDING)
  fulfillmentErrors                Json?
  paidAt                           DateTime?
  /**
   * Ship Pulse deadline (paidAt + 10d, or extended after buyer accepts a delay request).
   */
  shipDeadlineAt                   DateTime?
  /**
   * Set when Ship Pulse auto-cancel runs (idempotent with buyer email).
   */
  autoCancelledAt                  DateTime?
  fulfillmentMessages              OrderFulfillmentMessage[]
  shipExtensions                   OrderShipExtension[]
  fulfilledAt                      DateTime?
  /**
   * AutoDS dropship — external order id (idempotent create via API).
   */
  autodsOrderId                    String?                      @unique
  /**
   * PENDING | PROCESSING | SHIPPED | DELIVERED | FAILED
   */
  autodsStatus                     String?
  autodsTracking                   String?
  autodsTrackingUrl                String?
  autodsCarrier                    String?
  /**
   * Idempotent buyer shipped email after AutoDS webhook/cron.
   */
  autodsShippedEmailSentAt         DateTime?
  autodsFulfillmentLogs            AutodsFulfillmentLog[]
  trackingEvents                   OrderTrackingEvent[]
  autoFulfillmentBatchId           String?
  autoFulfillmentBatch             AutoFulfillmentBatch?        @relation(fields: [autoFulfillmentBatchId], references: [id], onDelete: SetNull)

  supplierFulfillmentLinks SupplierFulfillmentOrderLine[]
  stripeRefunds            OrderStripeRefund[]
  transferReversals        TransferReversal[]
  transferAttempts         TransferAttempt[]
  autoBuyLog               FulfillmentLog?

  @@index([affiliateId])
  @@index([splitStatus])
  @@index([supplierId, status, shipDeadlineAt])
  @@index([autodsStatus, createdAt])
}

model TransferAttempt {
  id               String         @id @default(cuid())
  orderId          String
  role             TransferRole
  amountCents      Int
  /**
   * Cumulative Stripe reversal applied to this transfer (partial refunds increment).
   */
  reversedAmountCents Int            @default(0)
  destination      String
  status           TransferStatus @default(PENDING)
  stripeTransferId String?
  errorCode        String?
  errorMessage     String?
  attempts         Int            @default(0)
  lastAttemptAt    DateTime?
  createdAt        DateTime       @default(now())
  order            Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, role])
  @@index([status, attempts])
}

/**
 * Stripe refund rows + commission clawback (Connect settlement).
 */
model OrderStripeRefund {
  id                      String   @id @default(cuid())
  orderId                 String
  order                   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  stripeRefundId          String   @unique
  amountCents             Int
  commissionReturnedCents Int
  taxReturnedCents        Int      @default(0)
  reason                  String?
  createdAt               DateTime @default(now())

  @@index([orderId])
}

/**
 * Stripe Connect transfer reversal audit — one row per transfer × refund attempt.
 */
model TransferReversal {
  id               String                 @id @default(cuid())
  orderId          String
  order            Order                  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  stripeRefundId   String
  stripeTransferId String
  stripeReversalId String?
  role             String
  requestedCents   Int
  amountCents      Int                    @default(0)
  status           TransferReversalStatus
  errorMessage     String?
  idempotencyKey   String                 @unique
  createdAt        DateTime               @default(now())

  @@index([orderId])
  @@index([stripeRefundId])
  @@index([stripeTransferId])
  @@index([orderId, status])
}

/**
 * Supplier / affiliate payout & clawback audit (idempotent keys per order + role).
 */
model MerchantPayoutLedger {
  id                   String              @id @default(cuid())
  orderId              String?
  order                Order?              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  blindDropshipOrderId String?
  blindDropshipOrder   BlindDropshipOrder? @relation(fields: [blindDropshipOrderId], references: [id], onDelete: Cascade)
  userId               String
  user                 User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  beneficiaryRole      String
  entryType            String
  amountCents          Int
  idempotencyKey       String              @unique
  /**
   * Stripe Connect transfer id — set when money actually moved (connect | lightning rails).
   */
  stripeTransferId     String?             @unique
  /**
   * connect | lightning | ledger_only (blind dropship internal obligation).
   */
  payoutRail           String              @default("ledger_only")
  note                 String?             @db.Text
  createdAt            DateTime            @default(now())

  @@index([orderId])
  @@index([blindDropshipOrderId])
  @@index([userId, createdAt])
  @@index([payoutRail, createdAt])
}

enum OrderShipExtensionStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

/**
 * Immutable tracking audit trail per marketplace order (litiges, conformité UE).
 */
model OrderTrackingEvent {
  id                 String   @id @default(cuid())
  orderId            String
  order              Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  eventType          String
  source             String
  trackingCarrier    String?
  trackingNumber     String?
  fulfillmentStatus  String?
  verificationMethod String?
  idempotencyKey     String   @unique
  payload            Json?
  createdAt          DateTime @default(now())

  @@index([orderId, createdAt])
  @@index([trackingNumber])
}

/**
 * Buyer ↔ supplier thread on an open marketplace order (delay explanations).
 */
model OrderFulfillmentMessage {
  id           String   @id @default(cuid())
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  authorRole   String
  authorUserId String?
  body         String   @db.Text
  createdAt    DateTime @default(now())

  @@index([orderId, createdAt])
}

/**
 * Supplier asks buyer for extra ship time after the initial 10-day window.
 */
model OrderShipExtension {
  id               String                   @id @default(cuid())
  orderId          String
  order            Order                    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  reason           String                   @db.Text
  extraDays        Int
  status           OrderShipExtensionStatus @default(PENDING)
  buyerRespondedAt DateTime?
  buyerNote        String?                  @db.Text
  newDeadlineAt    DateTime?
  buyerExpiresAt   DateTime
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  @@index([orderId, status])
  @@index([status, buyerExpiresAt])
}

/**
 * Marketplace-style return case (requested → seller decision → ship back → received → refunded).
 * Status values are enforced in application code; see `lib/order-return-state.ts`.
 */
model OrderReturn {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  buyerUserId String?
  buyer       User?   @relation("BuyerOrderReturns", fields: [buyerUserId], references: [id], onDelete: SetNull)

  status String @default("REQUESTED")

  reasonCode   String
  reasonDetail String?
  /**
   * JSON string[] — photo / video evidence URLs.
   */
  evidenceUrls Json    @default("[]")

  /**
   * Amount buyer asks to recover (usually order line total).
   */
  requestedRefundCents Int
  approvedRefundCents  Int?

  sellerNote      String?
  rejectionReason String?

  buyerTrackingCarrier String?
  buyerTrackingNumber  String?
  buyerShippedAt       DateTime?

  /**
   * Seller should approve or reject by this time (SLA hint).
   */
  sellerRespondByAt DateTime?

  receivedAt DateTime?
  refundedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([status])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  message   String
  /**
   * Product thumbnail for the variant chosen at purchase (orders / sales alerts).
   */
  imageUrl  String?
  orderId   String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

/**
 * Affiliate-shared link inviting a supplier to join Affisell and list SKUs.
 * Public token in URL (`/invite/supplier/[token]`).
 */
model AffiliateSupplierInvitation {
  id                   String    @id @default(cuid())
  /**
   * Public slug, e.g. INV-XXXXXXXXXXXX
   */
  token                String    @unique
  affiliateId          String
  affiliate            User      @relation("AffiliateSupplierInvites", fields: [affiliateId], references: [id], onDelete: Cascade)
  headline             String    @default("")
  personalMessage      String    @default("") @db.Text
  /**
   * Optional commission pitch shown on the invite (catalog default may differ).
   */
  offeredCommissionPct Float?
  categoryHint         String?
  /**
   * OPEN → REGISTERED (signup) → CATALOG_LIVE (first published SKU).
   */
  status               String    @default("OPEN")
  viewCount            Int       @default(0)
  supplierId           String?   @unique
  supplier             User?     @relation("SupplierFromInvite", fields: [supplierId], references: [id], onDelete: SetNull)
  registeredAt         DateTime?
  firstProductId       String?
  catalogLiveAt        DateTime?
  expiresAt            DateTime
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([affiliateId, createdAt])
  @@index([status])
}

/**
 * Supplier-shared link inviting an affiliate to join Affisell and list the supplier's SKUs.
 * Public token in URL (`/invite/affiliate/[token]`).
 */
model SupplierAffiliateInvitation {
  id                   String    @id @default(cuid())
  /**
   * Public slug, e.g. IAF-XXXXXXXXXXXX
   */
  token                String    @unique
  supplierId           String
  supplier             User      @relation("SupplierAffiliateInvites", fields: [supplierId], references: [id], onDelete: Cascade)
  headline             String    @default("")
  personalMessage      String    @default("") @db.Text
  offeredCommissionPct Float?
  categoryHint         String?
  /**
   * OPEN → REGISTERED (signup) → LISTING_LIVE (first public listing of inviter SKU).
   */
  status               String    @default("OPEN")
  viewCount            Int       @default(0)
  affiliateId          String?   @unique
  affiliate            User?     @relation("AffiliateFromSupplierInvite", fields: [affiliateId], references: [id], onDelete: SetNull)
  registeredAt         DateTime?
  firstListingId       String?
  listingLiveAt        DateTime?
  expiresAt            DateTime
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([supplierId, createdAt])
  @@index([status])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

/**
 * One-time password reset (hashed token, 1h TTL).
 */
model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// --- Blind dropship (parallel to native Affisell checkout; supplier APIs see wholesale only) ---

model BlindDropshipSupplier {
  id              String    @id @default(cuid())
  /**
   * Affisell supplier user this API profile belongs to (one profile per supplier).
   */
  linkedUserId    String    @unique
  linkedUser      User      @relation(fields: [linkedUserId], references: [id], onDelete: Cascade)
  name            String
  /**
   * rest | csv | browser
   */
  apiType         String    @default("rest")
  apiEndpoint     String?
  /**
   * AES-GCM sealed secret; never sent to partners.
   */
  apiKeyEncrypted String    @db.Text
  /**
   * card_per_order | wallet
   */
  billingType     String    @default("wallet")
  isBlindDropship Boolean   @default(true)
  /**
   * webhookSecret (HMAC), stripeConnectAccountId, inventoryPath, createOrderPath, slack alerts, etc.
   */
  config          Json      @default("{}")
  lastStockSyncAt DateTime?
  lastStockError  String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  orderItems          BlindDropshipOrderItem[]
  fulfillmentProvider FulfillmentProvider?
}

model BlindDropshipOrder {
  id                           String    @id @default(cuid())
  affiliateId                  String
  affiliate                    User      @relation("BlindDropshipAffiliateOrders", fields: [affiliateId], references: [id], onDelete: Restrict)
  buyerUserId                  String?
  buyer                        User?     @relation("BlindDropshipBuyerOrders", fields: [buyerUserId], references: [id], onDelete: SetNull)
  customerEmail                String
  shippingAddress              Json
  totalPaidCents               Int
  totalCostCents               Int       @default(0)
  marginCents                  Int       @default(0)
  affisellFeeCents             Int       @default(0)
  affiliateCommissionCents     Int       @default(0)
  affiliateMarginRetainedCents Int       @default(0)
  /**
   * pending_payment | paid | fulfilling | shipped | failed | refunded | awaiting_manual_payment
   */
  status                       String    @default("pending_payment")
  stripePaymentIntentId        String?   @unique
  trackingCarrier              String?
  trackingNumber               String?
  deliveredAt                  DateTime?
  deliveryConfirmedAt          DateTime?
  deliveryConfirmedBy          String?
  payoutEligibleAt             DateTime?
  supplierPayoutAt             DateTime?
  affiliatePayoutAt            DateTime?
  lastFulfillError             String?   @db.Text
  inngestRunId                 String?
  createdAt                    DateTime  @default(now())
  updatedAt                    DateTime  @updatedAt

  items                BlindDropshipOrderItem[]
  merchantPayoutLedger MerchantPayoutLedger[]

  @@index([affiliateId, status])
  @@index([status, createdAt])
}

model BlindDropshipOrderItem {
  id                           String                @id @default(cuid())
  blindDropshipOrderId         String
  order                        BlindDropshipOrder    @relation(fields: [blindDropshipOrderId], references: [id], onDelete: Cascade)
  affiliateProductId           String
  affiliateProduct             AffiliateProduct      @relation(fields: [affiliateProductId], references: [id], onDelete: Restrict)
  productId                    String
  product                      Product               @relation(fields: [productId], references: [id], onDelete: Restrict)
  blindDropshipSupplierId      String
  blindDropshipSupplier        BlindDropshipSupplier @relation(fields: [blindDropshipSupplierId], references: [id], onDelete: Restrict)
  quantity                     Int                   @default(1)
  supplierPriceAtOrderCents    Int
  supplierSkuAtOrder           String
  linePaidCents                Int                   @default(0)
  marginCents                  Int                   @default(0)
  affisellFeeCents             Int                   @default(0)
  affiliateCommissionCents     Int                   @default(0)
  affiliateMarginRetainedCents Int                   @default(0)
  /**
   * Partner reference after createOrder succeeds.
   */
  supplierOrderId              String?
  createdAt                    DateTime              @default(now())

  @@index([blindDropshipOrderId])
  @@index([supplierOrderId])
}

// ─── Universal Auto-Order Engine v1 ───────────────────────────────────────────

enum SupplierChannelType {
  AFFISELL_NATIVE
  ALIEXPRESS
  CJ_DROPSHIPPING
  TEMU
  BIGBUY
  ZENDROP
  AMAZON
  TIKTOK_SHOP
  BLIND_REST
  MANUAL
}

enum FulfillmentProviderStatus {
  ACTIVE
  PAUSED
  DISABLED
}

enum FulfillmentPaymentMethod {
  STRIPE_ISSUING
  STRIPE_CONNECT
  WALLET_PREPAID
  INVOICE_NET30
  NONE
}

enum FulfillmentStatus {
  PENDING
  PROCESSING
  PARTIAL
  ORDERED
  SHIPPED
  DELIVERED
  FAILED
  MANUAL_REQUIRED
}

enum SupplierFulfillmentStatus {
  PENDING
  PROCESSING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
  FAILED
}

enum AutoFulfillmentBatchStatus {
  PENDING
  PROCESSING
  COMPLETED
  PARTIAL
  FAILED
}

/**
 * Configured supplier channel (maps to Affisell User supplier and/or blind REST partner).
 */
model FulfillmentProvider {
  id                      String                    @id @default(cuid())
  slug                    String                    @unique
  name                    String
  channelType             SupplierChannelType
  status                  FulfillmentProviderStatus @default(ACTIVE)
  /**
   * Non-secret config: endpoints, timeouts, version.
   */
  apiConfig               Json                      @default("{}")
  /**
   * AES-encrypted credentials blob — never expose to client.
   */
  credentialsEncrypted    String?                   @db.Text
  paymentMethod           FulfillmentPaymentMethod  @default(NONE)
  stripeConnectAccountId  String?
  commissionRateBps       Int                       @default(0)
  walletBalanceCents      Int                       @default(0)
  slaHours                Int                       @default(24)
  metadata                Json?
  /**
   * Native Affisell supplier user (role SUPPLIER).
   */
  supplierUserId          String?
  blindDropshipSupplierId String?                   @unique
  blindDropshipSupplier   BlindDropshipSupplier?    @relation(fields: [blindDropshipSupplierId], references: [id], onDelete: SetNull)
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt

  supplierJobs SupplierFulfillmentOrder[]

  @@index([channelType, status])
  @@index([supplierUserId])
}

/**
 * One checkout session → N supplier purchase jobs (event-driven batch).
 */
model AutoFulfillmentBatch {
  id                String                     @id @default(cuid())
  stripeSessionId   String                     @unique
  status            AutoFulfillmentBatchStatus @default(PENDING)
  fulfillmentStatus FulfillmentStatus          @default(PENDING)
  orderCount        Int                        @default(0)
  supplierJobCount  Int                        @default(0)
  errors            Json?
  idempotencyKey    String                     @unique
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  marketplaceOrders Order[]
  supplierJobs      SupplierFulfillmentOrder[]

  @@index([status, createdAt])
}

/**
 * Purchase placed (or queued) with an external/native supplier for one or more marketplace Order rows.
 */
model SupplierFulfillmentOrder {
  id                    String                    @id @default(cuid())
  batchId               String
  batch                 AutoFulfillmentBatch      @relation(fields: [batchId], references: [id], onDelete: Cascade)
  fulfillmentProviderId String
  provider              FulfillmentProvider       @relation(fields: [fulfillmentProviderId], references: [id])
  supplierOrderId       String?                   @unique
  status                SupplierFulfillmentStatus @default(PENDING)
  totalCostCents        Int                       @default(0)
  currency              String                    @default("EUR")
  paymentMethod         FulfillmentPaymentMethod
  paymentReference      String?
  rawRequest            Json?
  rawResponse           Json?
  errorMessage          String?                   @db.Text
  attempts              Int                       @default(0)
  createdAt             DateTime                  @default(now())
  processedAt           DateTime?

  lines SupplierFulfillmentOrderLine[]

  @@index([batchId])
  @@index([fulfillmentProviderId, status])
}

model SupplierFulfillmentOrderLine {
  id                         String                   @id @default(cuid())
  supplierFulfillmentOrderId String
  supplierFulfillmentOrder   SupplierFulfillmentOrder @relation(fields: [supplierFulfillmentOrderId], references: [id], onDelete: Cascade)
  orderId                    String
  order                      Order                    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId                  String
  quantity                   Int
  unitCostCents              Int
  supplierSku                String?
  trackingNumber             String?
  trackingUrl                String?
  fulfilledAt                DateTime?

  @@unique([supplierFulfillmentOrderId, orderId])
  @@index([orderId])
}

/// Meta AI ad video for a supplier product (marketplace affiliates download when DONE).
model VideoGenerationJob {
  id           String   @id @default(cuid())
  productId    String
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  /**
   * External Meta AI job id returned by POST /v1/video
   */
  jobId        String?  @unique
  prompt       String   @db.Text
  format       String   @default("9:16") // 9:16 | 1:1 | 16:9
  status       String   @default("PROCESSING") // PROCESSING | DONE | FAILED
  videoUrl     String?
  thumbnailUrl String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([productId])
  @@index([status])
}

/**
 * AliExpress sourcing + auto-buy config (1:1 Product).
 */
model SupplierLink {
  id        String  @id @default(cuid())
  productId String  @unique
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  aeProductId     String
  aeSkuId         String?
  aeShopId        String  @default("")
  aePriceCents    Int
  aeShippingCents Int     @default(0)
  aeUrl           String

  autoBuyEnabled Boolean   @default(true)
  lastSyncAt     DateTime?
  isActive       Boolean   @default(true)

  variantMappings SupplierLinkVariant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([aeProductId])
}

/**
 * Per Affisell variant (color/size) → AliExpress SKU + purchase price for auto-buy.
 */
model SupplierLinkVariant {
  id               String          @id @default(cuid())
  supplierLinkId   String
  supplierLink     SupplierLink    @relation(fields: [supplierLinkId], references: [id], onDelete: Cascade)
  productVariantId String?
  productVariant   ProductVariant? @relation(fields: [productVariantId], references: [id], onDelete: SetNull)
  /**
   * Normalized color key for order.variantLabel matching when no ProductVariant row.
   */
  matchColor       String?
  matchSize        String?
  aeSkuId          String
  aePriceCents     Int
  aeShippingCents  Int             @default(0)
  aeLabel          String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@unique([supplierLinkId, productVariantId])
  @@index([supplierLinkId])
  @@index([supplierLinkId, matchColor])
}

/**
 * AutoDS webhook/cron audit trail (provider events).
 */
model AutodsFulfillmentLog {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider  String   @default("autods")
  event     String
  response  Json?
  createdAt DateTime @default(now())

  @@index([orderId, createdAt])
}

/**
 * WooCommerce REST keys issued to third-party apps (e.g. AutoDS onboarding).
 */
model WooCommerceApiCredential {
  id              String    @id @default(cuid())
  appName         String
  externalUserId  String
  consumerKey     String    @unique
  consumerSecret  String
  scope           String
  keyPermissions  String?
  grantedByUserId String?
  createdAt       DateTime  @default(now())
  revokedAt       DateTime?

  @@index([externalUserId, appName])
  @@index([revokedAt])
}

/**
 * Per marketplace order — AliExpress auto-buy lifecycle (distinct from Order.fulfillmentStatus).
 */
model FulfillmentLog {
  id            String        @id @default(cuid())
  orderId       String        @unique
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  /**
   * Affisell 1 order = 1 product — mirrors orderId for API compatibility.
   */
  orderItemId   String
  status        AutoBuyStatus @default(PENDING)
  aeOrderId     String?
  aeTracking    String?
  virtualCardId String?
  errorMsg      String?       @db.Text
  attempts      Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status])
}

enum AutoBuyStatus {
  PENDING
  BUYING
  BOUGHT
  FAILED
  REFUNDED
}

enum DemoPersona {
  SUPPLIER
  AFFILIATE
  BUYER
}

/**
 * In-app demo lab — structured UX feedback (suppliers, affiliates, buyers).
 */
model DemoFeedback {
  id        String      @id @default(cuid())
  persona   DemoPersona
  score     Int
  comment   String?     @db.Text
  email     String?
  locale    String?
  stepId    String?
  createdAt DateTime    @default(now())

  @@index([persona, createdAt])
}

/**
 * ROW buyer interest — notify when checkout opens in their country (idempotent per email+country+region).
 */
model CheckoutLaunchWaitlist {
  id                      String    @id @default(cuid())
  email                   String
  countryIso2             String
  marketRegion            String
  locale                  String?
  launchNotifiedAt        DateTime?
  launchFollowUpSentAt    DateTime?
  launchEmailBouncedAt    DateTime?
  launchEmailSuppressedAt DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  @@unique([email, countryIso2, marketRegion])
  @@index([countryIso2, marketRegion])
  @@index([marketRegion, createdAt])
  @@index([countryIso2, marketRegion, launchNotifiedAt])
  @@index([marketRegion, launchEmailBouncedAt])
  @@index([marketRegion, launchEmailSuppressedAt])
}

/**
 * Founder-enabled checkout countries beyond the static EU/US base list.
 */
model CheckoutCountryRollout {
  id                    String    @id @default(cuid())
  countryIso2           String
  marketRegion          String
  enabled               Boolean   @default(true)
  openedAt              DateTime  @default(now())
  launchEmailSentAt     DateTime?
  firstOrderAt          DateTime?
  firstOrderId          String?
  graduatedAt           DateTime?
  graduationEmailSentAt DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([countryIso2, marketRegion])
  @@index([marketRegion, enabled])
  @@index([marketRegion, firstOrderAt])
  @@index([marketRegion, graduatedAt])
}

/**
 * Short-lived buffer: bookmarklet POST → admin poll (serverless-safe).
 */
model AdminAeCaptureSession {
  id        String   @id @default(cuid())
  productId String
  result    Json?
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([productId, expiresAt])
}

/**
 * Admin Sentinel — auto-detected ops issues (id = stable hash, idempotent upsert).
 */
model OpsSignal {
  id         String    @id
  severity   String
  domain     String
  code       String
  title      String
  detail     String    @db.Text
  metric     Int?
  entityType String?
  entityId   String?
  playbook   String?
  detectedAt DateTime  @default(now())
  resolvedAt DateTime?
  lastSeenAt DateTime  @default(now())

  @@index([resolvedAt, severity, lastSeenAt])
  @@index([domain, code])
}

/**
 * Sentinel scan history — health score trend (one row per cron/manual scan).
 */
model OpsScanSnapshot {
  id        String   @id @default(cuid())
  scannedAt DateTime @default(now())
  score     Int
  openP0    Int      @default(0)
  openP1    Int      @default(0)
  openP2    Int      @default(0)
  openP3    Int      @default(0)
  detected  Int      @default(0)
  resolved  Int      @default(0)

  @@index([scannedAt])
}

/**
 * Stripe webhook idempotence (event.id = evt_…).
 */
model ProcessedWebhook {
  id        String   @id
  orderId   String?
  status    String
  error     String?  @db.Text
  createdAt DateTime @default(now())

  @@index([orderId])
}

enum AgentCapability {
  QC_INSPECTION
  COMPLIANCE
  PHOTO_PROOF
  REPACK_EXPRESS
}

enum AgentStatus {
  PENDING
  ACTIVE
  PAUSED
  REJECTED
}

enum AgentMissionType {
  QC_INSPECTION
  COMPLIANCE_CHECK
  PHOTO_PROOF
  REPACK_EXPRESS
}

enum AgentMissionStatus {
  REQUESTED
  ASSIGNED
  IN_PROGRESS
  PASSED
  FAILED
  CANCELLED
}

enum ChinaBuyRouteStatus {
  STUB
  ROUTED
  API_OK
  API_FAIL
}

enum AgentLedgerEntryType {
  CREDIT
  DEBIT
}

/**
 * Affisell Agent Network — vetted local agents (QC, compliance, photo proof, express relay).
 */
model SourcingAgent {
  id                    String            @id @default(cuid())
  displayName           String
  /**
   * ISO-3166 alpha-2 (CN, TR, VN, …).
   */
  country               String
  city                  String
  capabilities          AgentCapability[]
  languages             String[]          @default([])
  /**
   * Rating ×10 (47 = 4.7★).
   */
  ratingX10             Int               @default(45)
  missionsDone          Int               @default(0)
  /**
   * Avg turnaround from assignment to report.
   */
  leadTimeHours         Int               @default(48)
  /**
   * Available balance (mission fees credited on PASSED).
   */
  balanceCents          Int               @default(0)
  lifetimeEarningsCents Int               @default(0)
  status                AgentStatus       @default(PENDING)
  contactEmail          String            @unique
  /**
   * Motivation / expérience (candidature publique).
   */
  applicationNote       String?           @db.Text
  contactPhone          String?
  /**
   * Compte User (role AGENT) créé à l'activation admin.
   */
  userId                String?           @unique
  user                  User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @default(now()) @updatedAt

  missions      AgentMission[]
  ledgerEntries AgentLedgerEntry[]

  @@index([status, country])
}

/**
 * Inspection / express-relay mission requested by a supplier on one SKU.
 */
model AgentMission {
  id            String             @id @default(cuid())
  supplierId    String
  productId     String?
  product       Product?           @relation(fields: [productId], references: [id], onDelete: SetNull)
  agentId       String?
  agent         SourcingAgent?     @relation(fields: [agentId], references: [id], onDelete: SetNull)
  type          AgentMissionType
  status        AgentMissionStatus @default(REQUESTED)
  /**
   * Supplier brief (what to check, lot size, …).
   */
  instructions  String?            @db.Text
  /**
   * Structured findings (checklist, defects, measurements).
   */
  report        Json?
  reportSummary String?            @db.Text
  photoUrls     String[]           @default([])
  feeCents      Int                @default(0)
  /**
   * Supplier-flagged priority (display + matching boost later).
   */
  urgent        Boolean            @default(false)
  /**
   * Supplier deadline — SLA target for the agent.
   */
  deadlineAt    DateTime?
  /**
   * Quality Gate: FAILED mission paused this SKU's auto-buy.
   */
  autoBuyPaused Boolean            @default(false)
  requestedAt   DateTime           @default(now())
  assignedAt    DateTime?
  completedAt   DateTime?
  /**
   * SMS J+1 reminder sent when mission stays ASSIGNED > 24h.
   */
  smsReminderAt DateTime?
  updatedAt     DateTime           @default(now()) @updatedAt

  ledgerEntry AgentLedgerEntry?

  @@index([supplierId, status, requestedAt])
  @@index([agentId, status])
  @@index([productId])
  @@index([status, assignedAt, smsReminderAt])
}

/**
 * Audit trail for China buying agent routing (Superbuy, Anovabuy, …).
 */
model ChinaBuyRouteLog {
  id             String              @id @default(cuid())
  supplierId     String
  productId      String?
  product        Product?            @relation(fields: [productId], references: [id], onDelete: SetNull)
  agentId        String
  platform       String?
  sourceUrl      String
  status         ChinaBuyRouteStatus @default(STUB)
  externalRef    String?
  errorMessage   String?             @db.Text
  orderId        String?
  /**
   * Idempotent replay key: supplier + url + agent.
   */
  idempotencyKey String              @unique
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([supplierId, createdAt])
  @@index([productId])
  @@index([orderId])
  @@index([agentId, externalRef])
}

/**
 * Agent mission fee credits — one row per mission (idempotent on PASSED).
 */
model AgentLedgerEntry {
  id                String               @id @default(cuid())
  agentId           String
  agent             SourcingAgent        @relation(fields: [agentId], references: [id], onDelete: Cascade)
  missionId         String?              @unique
  mission           AgentMission?        @relation(fields: [missionId], references: [id], onDelete: SetNull)
  type              AgentLedgerEntryType
  amountCents       Int
  balanceAfterCents Int
  note              String?              @db.Text
  stripeTransferId  String?              @unique
  /**
   * Idempotent withdraw key — `withdraw:{agentId}:{uuid}`.
   */
  idempotencyKey    String?              @unique
  createdAt         DateTime             @default(now())

  @@index([agentId, createdAt])
}

enum TryOnJobStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

/**
 * Async Replicate prediction lifecycle (Vercel 10s timeout → webhook completion).
 */
model TryOnJob {
  id                    String         @id @default(cuid())
  status                TryOnJobStatus @default(PENDING)
  replicatePredictionId String?        @unique
  productId             String
  product               Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  affiliateProductId    String?
  inputUrl              String
  garmentUrl            String
  outputUrl             String?
  errorMessage          String?        @db.Text
  userId                String?
  user                  User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  anonId                String?
  ipHash                String?
  modelVersion          String         @default("idm-vton")
  latencyMs             Int?
  gdprConsentAt         DateTime
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  completedAt           DateTime?
  tryOn                 TryOn?

  @@index([status, createdAt])
  @@index([userId])
  @@index([anonId])
  @@index([ipHash])
}

/**
 * Cached try-on result for analytics + 24h dedupe by resultHash.
 */
model TryOn {
  id                 String    @id @default(cuid())
  jobId              String    @unique
  job                TryOnJob  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  userId             String?
  user               User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  anonId             String?
  productId          String
  product            Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  affiliateProductId String?
  inputUrl           String
  outputUrl          String
  modelVersion       String
  latencyMs          Int?
  angle              String    @default("front")
  resultHash         String    @unique
  inputDeletedAt     DateTime?
  outputExpiresAt    DateTime
  createdAt          DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([productId])
  @@index([resultHash])
  @@index([outputExpiresAt])
}
