// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

enum Role {
  SUPPLIER
  AFFILIATE
  ADMIN
}

enum Plan {
  GRATUIT
  BASIC
  PREMIUM
  GOLD
}

enum Category {
  ELEC
  MODE
  BEAUTE
  HOME
  AUTRE
}

enum OrderStatus {
  PENDING
  PAID
  DELIVERED
  COMPLETED
  CANCELLED
}

enum SplitRecipient {
  SUPPLIER
  AFFILIATE
  PLATFORM
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
}

model User {
  id String @id @default(cuid())
  name String?
  email String @unique
  emailVerified DateTime?
  image String?
  role Role @default(AFFILIATE)
  accounts Account[]
  sessions Session[]
  supplierProfile SupplierProfile?
  affiliateProfile AffiliateProfile?
  wallet Wallet?
  products Product[]
  createdAt DateTime @default(now())
}

model Account {
  id String @id @default(cuid())
  userId String
  type String
  provider String
  providerAccountId String
  refresh_token String? @db.Text
  access_token String? @db.Text
  expires_at Int?
  token_type String?
  scope String?
  id_token String? @db.Text
  session_state String?
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id String @id @default(cuid())
  sessionToken String @unique
  userId String
  expires DateTime
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token String @unique
  expires DateTime
  @@unique([identifier, token])
}

model SupplierProfile {
  id String @id @default(cuid())
  userId String @unique
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName String?
  plan Plan @default(GRATUIT)
  stripeAccountId String?
}

model AffiliateProfile {
  id String @id @default(cuid())
  userId String @unique
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan @default(GRATUIT)
  stripeAccountId String?
  bonusRate Int @default(5)
  store Store?
}

model Store {
  id String @id @default(cuid())
  slug String @unique
  name String
  affiliateId String @unique
  affiliate AffiliateProfile @relation(fields: [affiliateId], references: [id])
  storeProducts StoreProduct[]
}

model Product {
  id String @id @default(cuid())
  name String
  description String?
  price Int
  imageUrl String?
  commissionPercent Int @default(30)
  supplierId String
  active Boolean @default(true)
  createdAt DateTime @default(now())
  supplier User @relation(fields: [supplierId], references: [id])
  storeProducts StoreProduct[]
  orderItems OrderItem[]
  orders Order[]
}

model StoreProduct {
  id String @id @default(cuid())
  storeId String
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  productId String
  product Product @relation(fields: [productId], references: [id])
  affiliateMargin Float @default(0)
  @@unique([storeId, productId])
}

model Order {
  id                      String   @id @default(cuid())
  userId                  String?
  productId               String?
  product                 Product? @relation(fields: [productId], references: [id])
  affiliateId             String?
  stripePaymentIntentId   String?  @unique
  supplierStripeAccountId String?
  status                  String
  amount                  Int
  currency                String   @default("usd")
  deliverableAt           DateTime?
  confirmedAt             DateTime?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model OrderItem {
  id String @id @default(cuid())
  orderId String
  productId String
  product Product @relation(fields: [productId], references: [id])
  quantity Int @default(1)
  unitPrice Float
  supplierAmount Float
  affiliateAmount Float
  platformFee Float
}

model CommissionSplit {
  id String @id @default(cuid())
  orderId String
  recipientType SplitRecipient
  recipientId String?
  amount Float
  status PayoutStatus @default(PENDING)
}

model Wallet {
  id String @id @default(cuid())
  userId String @unique
  user User @relation(fields: [userId], references: [id])
  balance Float @default(0)
  transactions WalletTransaction[]
}

model WalletTransaction {
  id String @id @default(cuid())
  walletId String
  wallet Wallet @relation(fields: [walletId], references: [id])
  amount Float
  type String
  createdAt DateTime @default(now())
}
