datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  SUPPLIER
  AFFILIATE
  ADMIN
}

model User {
  id                  String             @id @default(cuid())
  name                String?
  email               String             @unique
  emailVerified       DateTime?
  image               String?
  role                Role               @default(AFFILIATE)
  password            String?
  createdAt           DateTime           @default(now())
  accounts            Account[]
  sessions            Session[]
  products            Product[]
  affiliateStore      AffiliateStore?
  affiliateSelections AffiliateProduct[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model AffiliateStore {
  id        String   @id @default(cuid())
  userId    String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model AffiliateProduct {
  id          String   @id @default(cuid())
  affiliateId String
  productId   String
  addedAt     DateTime @default(now())
  affiliate   User     @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([affiliateId, productId])
}

model Product {
  id                String             @id @default(cuid())
  name              String
  description       String?
  priceCents        Int
  image             String?
  stock             Int                @default(0)
  commissionPercent Int                @default(30)
  supplierId        String
  supplier          User               @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  active            Boolean            @default(true)
  createdAt         DateTime           @default(now())
  orders            Order[]
  affiliateLinks    AffiliateProduct[]
}

model Order {
  id                    String   @id @default(cuid())
  userId                String?
  productId             String?
  product               Product? @relation(fields: [productId], references: [id])
  affiliateId           String?
  supplierId            String?
  stripePaymentIntentId String?  @unique
  stripeSessionId       String?  @unique
  status                String
  amount                Int
  currency              String   @default("eur")
  deliverableAt         DateTime?
  confirmedAt           DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}
