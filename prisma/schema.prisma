// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  password      String?
  role          String    @default("CUSTOMER")
  createdAt     DateTime  @default(now())

  accounts Account[]
  sessions Session[]

  products Product[] @relation("SupplierProducts")
  affiliateProducts AffiliateProduct[]
  supplierOrders Order[] @relation("SupplierOrders")
  store Store?
  affiliateOrders Order[] @relation("AffiliateOrders")
  notifications Notification[]
  cart Cart?
  storeFollowRelations Follow[] @relation("UserFollowsStore")
  searchHistory      SearchHistory[]
  wishlists          Wishlist[]
}

model Store {
  id               String    @id @default(cuid())
  userId           String    @unique
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name             String
  slug             String    @unique
  logoUrl          String?
  bannerUrl        String?
  description      String?
  customDomain     String?   @unique
  domainVerified   Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  instagram            String?
  tiktok               String?
  youtube              String?
  twitch               String?
  facebook             String?
  twitter              String?
  followers            Json?
  showSocialsOnStore   Boolean   @default(true)
  autoSyncFollowersDaily Boolean @default(false)
  isLive               Boolean   @default(false)
  livePlatform         String?
  liveUrl              String?
  lastSyncAt           DateTime?

  communityPosts CommunityPost[]
  followerRelations Follow[] @relation("StoreFollowers")
}

model Product {
  id String @id @default(cuid())
  supplierId String
  name String
  description String
  createdAt DateTime @default(now())
  images String[] @default([])
  colorImages Json?
  categories String[] @default([])
  colors String[] @default([])
  variants Json?
  tags String[] @default([])
  basePriceCents Int
  compareAt Decimal?
  commissionRate Int
  stock Int @default(0)
  active Boolean @default(true)

  shippingCountry        String?
  warehouseType          String?
  warehouseCity          String?
  processingTime         Int      @default(1)
  deliveryMin            Int      @default(2)
  deliveryMax            Int      @default(5)
  shippingMethods        String[] @default([])
  freeShippingThreshold  Decimal?
  shippingCost           Decimal  @default(0)

  /** Marketplace display / API (e.g. "EU", "FR"). Distinct from `shippingCountry` filter fields. */
  shipsFrom     String?
  deliveryDays  Int?
  freeShipping  Boolean @default(false)
  /** Display source label (e.g. "seed"); API may expose as `supplier` string. */
  supplierTag   String?
  reviewCount   Int      @default(0)
  averageRating Float    @default(0)
  reviewSentiment String @default("neutral")

  supplier User @relation("SupplierProducts", fields: [supplierId], references: [id])
  affiliateProducts AffiliateProduct[]
  orders Order[]
  communityPosts CommunityPost[]
  wishlists Wishlist[]
  reviews Review[]
}

model Review {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  rating       Int
  author       String
  country      String?
  date         DateTime
  text         String   @db.Text
  images       String[] @default([])
  variant      String?
  helpful_count Int     @default(0)
  verified     Boolean  @default(true)
  sentiment    String   @default("neutral")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([rating])
}

model Wishlist {
  id                 String   @id @default(cuid())
  userId             String
  productId          String
  /** Optional target alert threshold chosen by shopper (in cents). */
  targetPriceCents   Int?
  /** Last daily seen price, used for "depuis hier" drop computation. */
  previousPriceCents Int?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId, updatedAt])
  @@index([productId, updatedAt])
}

model SearchHistory {
  id         String   @id @default(cuid())
  userId     String?
  sessionId  String?
  query      String
  productId  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([sessionId, createdAt])
}

/** Homepage carousel analytics (view / hover / add-to-cart). */
model AffisellTrackEvent {
  id         String   @id @default(cuid())
  eventType  String
  productId  String?
  sessionId  String?
  userId     String?
  durationMs Int?
  createdAt  DateTime @default(now())

  @@index([productId, createdAt])
  @@index([eventType, createdAt])
  @@index([sessionId, createdAt])
}

model CommunityPost {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  content   String
  images    String[] @default([])
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  likes     Int      @default(0)
  createdAt DateTime @default(now())
}

model Follow {
  id        String   @id @default(cuid())
  userId    String
  storeId   String
  user      User     @relation("UserFollowsStore", fields: [userId], references: [id], onDelete: Cascade)
  store     Store    @relation("StoreFollowers", fields: [storeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, storeId])
}

model AffiliateProduct {
  id String @id @default(cuid())
  affiliateId String
  productId String
  affiliate User @relation(fields: [affiliateId], references: [id])
  product Product @relation(fields: [productId], references: [id])
  cartItems CartItem[]

  sellingPriceCents Int

  customTitle       String?
  customDescription String?
  customImages      String[] @default([])

  customSlug      String?
  seoTitle        String?
  seoDescription  String?
  collections     String[] @default([])

  isListed   Boolean @default(true)
  isFeatured Boolean @default(false)
  position   Int     @default(0)

  clicks       Int @default(0)
  conversions  Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([affiliateId, productId])
  @@unique([affiliateId, customSlug])
}

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
}

model CartItem {
  id                 String           @id @default(cuid())
  cartId             String
  affiliateProductId String
  quantity           Int              @default(1)
  cart               Cart             @relation(fields: [cartId], references: [id], onDelete: Cascade)
  affiliateProduct   AffiliateProduct @relation(fields: [affiliateProductId], references: [id], onDelete: Cascade)

  @@unique([cartId, affiliateProductId])
}

model Order {
  id String @id @default(cuid())
  productId String
  affiliateProductId String
  supplierId String
  affiliateId String
  customerEmail String
  shippingAddress Json
  basePriceCents Int
  sellingPriceCents Int
  commissionCents Int
  marginCents Int
  affiliatePayoutCents Int
  status String @default("paid")
  stripeSessionId String @unique
  createdAt DateTime @default(now())
  product Product @relation(fields: [productId], references: [id])
  supplier User @relation("SupplierOrders", fields: [supplierId], references: [id])
  affiliate User @relation("AffiliateOrders", fields: [affiliateId], references: [id])
}

model Notification {
  id String @id @default(cuid())
  userId String
  type String
  message String
  orderId String?
  read Boolean @default(false)
  createdAt DateTime @default(now())
  user User @relation(fields: [userId], references: [id])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
