/// Affisell Radar V3 — isolated Postgres.
/// URL: RADAR_DATABASE_URL (fallback MARKET_INTELLI_DATABASE_URL via scripts).
/// Generate: npx prisma generate --schema=prisma/radar.schema.prisma
/// Push: npm run radar:db:push

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client-mi"
}

datasource db {
  provider = "postgresql"
  url      = env("RADAR_DATABASE_URL")
  schemas  = ["market_intelli"]
}

model ShopConnection {
  id              String    @id @default(cuid())
  userId          String
  connectorId     String
  category        String
  region          String
  shopId          String
  shopName        String
  accessToken     String
  refreshToken    String?
  expiresAt       DateTime?
  merchantId      String?
  marketplaceMeta Json?
  scopes          String[]  @default([])
  status          String    @default("active")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([userId, connectorId, shopId])
  @@index([userId])
  @@index([connectorId])
  @@index([shopId])
  @@schema("market_intelli")
}

model StandardProduct {
  id           String   @id @default(cuid())
  connectorId  String
  externalId   String
  shopId       String?
  title        String?
  currency     String?
  price        Decimal? @db.Decimal(12, 2)
  sales        Int?
  rank         Int?
  views        Int?
  region       String?
  day          DateTime
  raw          Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([connectorId, externalId, day])
  @@index([connectorId, day])
  @@index([shopId])
  @@schema("market_intelli")
}

model GoogleProductInsight {
  id            String   @id @default(cuid())
  userId        String
  merchantId    String?
  offerId       String?
  title         String?
  impressions   Int?
  clicks        Int?
  ctr           Float?
  queries       Json?
  raw           Json?
  day           DateTime
  createdAt     DateTime @default(now())

  @@unique([userId, offerId, day])
  @@index([userId, day])
  @@index([merchantId])
  @@schema("market_intelli")
}

model WebhookEvent {
  id         String   @id @default(cuid())
  externalId String   @unique
  topic      String?
  shopId     String?
  connectorId String?
  payload    Json?
  createdAt  DateTime @default(now())

  @@index([shopId])
  @@index([connectorId])
  @@index([createdAt])
  @@schema("market_intelli")
}

model RadarGlobalSnapshot {
  id            String   @id @default(cuid())
  marketplaceId String
  externalId    String
  title         String
  price         Decimal  @db.Decimal(12, 2)
  category      String?
  country       String
  rank          Int?
  salesEst      Int?
  url           String?
  currency      String?
  imageUrl      String?
  crawledAt     DateTime @default(now())

  @@unique([marketplaceId, externalId, country])
  @@index([marketplaceId, category, crawledAt])
  @@index([crawledAt])
  @@schema("market_intelli")
}
