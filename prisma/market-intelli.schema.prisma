/// Alias schema — canonical is prisma/radar.schema.prisma
/// Kept so legacy `npx prisma generate --schema=prisma/market-intelli.schema.prisma` still resolves.
/// Prefer: npm run radar:db:push

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client-mi"
}

datasource db {
  provider = "postgresql"
  url      = env("MARKET_INTELLI_DATABASE_URL")
  schemas  = ["market_intelli"]
}

model ShopConnection {
  id              String    @id @default(cuid())
  userId          String
  connectorId     String
  category        String
  region          String
  shopId          String
  shopName        String
  accessToken     String
  refreshToken    String?
  expiresAt       DateTime?
  merchantId      String?
  marketplaceMeta Json?
  scopes          String[]  @default([])
  status          String    @default("active")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([userId, connectorId, shopId])
  @@index([userId])
  @@index([connectorId])
  @@index([shopId])
  @@schema("market_intelli")
}

model StandardProduct {
  id           String   @id @default(cuid())
  /// Marketplace / connector id (amazon, tiktok_shop, …) — GMC feed key part 1
  connectorId  String
  externalId   String
  country      String   @default("US")
  shopId       String?
  title        String?
  description  String?  @db.Text
  brand        String?
  currency     String?
  price        Decimal? @db.Decimal(12, 2)
  imageUrl     String?
  link         String?
  availability String   @default("in_stock")
  condition    String   @default("new")
  sales        Int?
  rank         Int?
  views        Int?
  region       String?
  day          DateTime @db.Date
  raw          Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([connectorId, externalId, country, day])
  @@index([connectorId, day])
  @@index([country, day])
  @@index([shopId])
  @@schema("market_intelli")
}

model GoogleProductInsight {
  id          String   @id @default(cuid())
  userId      String
  merchantId  String?
  offerId     String?
  title       String?
  impressions Int?
  clicks      Int?
  ctr         Float?
  queries     Json?
  raw         Json?
  day         DateTime
  createdAt   DateTime @default(now())

  @@unique([userId, offerId, day])
  @@index([userId, day])
  @@index([merchantId])
  @@schema("market_intelli")
}

model WebhookEvent {
  id          String   @id @default(cuid())
  externalId  String   @unique
  topic       String?
  shopId      String?
  connectorId String?
  payload     Json?
  createdAt   DateTime @default(now())

  @@index([shopId])
  @@index([connectorId])
  @@index([createdAt])
  @@schema("market_intelli")
}

/// Daily product snapshot (Affisell radar "ProductSnapshot").
model RadarGlobalSnapshot {
  id            String   @id @default(cuid())
  marketplaceId String
  externalId    String
  title         String
  price         Decimal  @db.Decimal(12, 2)
  category      String?
  country       String
  day           DateTime @db.Date @default(dbgenerated("CURRENT_DATE"))
  rank          Int?
  salesEst      Int?
  url           String?
  currency      String?
  imageUrl      String?
  crawledAt     DateTime @default(now())

  @@unique([marketplaceId, externalId, country, day])
  @@index([day])
  @@index([externalId, day])
  @@index([marketplaceId, category, crawledAt])
  @@index([marketplaceId, externalId, country, day])
  @@index([crawledAt])
  @@schema("market_intelli")
}
