{
  "name": "affisell-market",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "prisma generate && node ./scripts/next-dev-port.mjs",
    "postinstall": "prisma generate",
    "build": "prisma generate && next build",
    "db:push": "prisma db push",
    "db:local:up": "docker compose up -d",
    "worker:auto-order": "tsx workers/auto-order-worker.ts",
    "db:local:down": "docker compose down",
    "db:local:setup": "docker compose up -d && sleep 3 && DATABASE_URL=postgresql://affisell:affisell@localhost:5433/affisell npm run db:push && DATABASE_URL=postgresql://affisell:affisell@localhost:5433/affisell npx prisma db seed",
    "db:migrate": "prisma migrate deploy",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:copy": "tsx scripts/copy-to-prod.ts",
    "db:backfill-images": "tsx prisma/backfill-product-images.ts",
    "reclassify-products": "tsx scripts/reclassify-products.ts",
    "verify:sentry": "tsx scripts/verify-sentry.ts",
    "email:dev": "email dev --dir emails",
    "verify:no-secrets": "node scripts/verify-no-secrets.mjs",
    "push:safe": "npm run verify:no-secrets && git pull --rebase origin main && git push origin main",
    "test:veo": "tsx test-veo.ts",
    "test:veo:pipeline": "tsx scripts/test-veo-pipeline.ts",
    "test:vat": "tsx scripts/test-vat-flow.ts",
    "test:vat:math": "tsx scripts/test-vat-flow.ts --math-only",
    "test:vat:check": "tsx scripts/check-order-vat.ts",
    "test:vat:settle": "tsx scripts/resettle-order-vat.ts"
  },
