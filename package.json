{
  "name": "affisell-market",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "prisma generate && node ./scripts/next-dev-port.mjs",
    "postinstall": "prisma generate",
    "build": "prisma generate && next build",
    "db:push": "prisma db push",
    "db:local:up": "docker compose up -d",
    "db:local:down": "docker compose down",
    "db:local:setup": "docker compose up -d && sleep 3 && DATABASE_URL=postgresql://affisell:affisell@localhost:5433/affisell npm run db:push && DATABASE_URL=postgresql://affisell:affisell@localhost:5433/affisell npx prisma db seed",
    "db:migrate": "prisma migrate deploy",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:copy": "tsx scripts/copy-to-prod.ts",
    "db:backfill-images": "tsx prisma/backfill-product-images.ts",
    "reclassify-products": "tsx scripts/reclassify-products.ts",
    "verify:sentry": "tsx scripts/verify-sentry.ts",
    "test:veo": "tsx test-veo.ts",
    "test:veo:pipeline": "tsx scripts/test-veo-pipeline.ts"
  },
  "dependencies": {
    "@ai-sdk/groq": "^3.0.38",
    "@ai-sdk/react": "^3.0.177",
    "@auth/prisma-adapter": "^2.11.2",
    "@aws-sdk/client-s3": "^3.1044.0",
    "@aws-sdk/s3-request-presigner": "^3.1044.0",
    "@base-ui/react": "^1.4.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@imgly/background-removal": "^1.7.0",
    "@imgly/background-removal-node": "^1.4.5",
    "@prisma/client": "^6.19.3",
    "@stripe/react-stripe-js": "^6.3.0",
    "@stripe/stripe-js": "^9.5.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.0",
    "@vercel/blob": "^2.3.3",
    "ai": "^6.0.175",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.38.0",
    "google-auth-library": "^10.6.2",
    "groq-sdk": "^1.1.2",
    "inngest": "^4.4.0",
    "lucide-react": "^1.11.0",
    "next": "16.2.4",
    "next-auth": "^5.0.0-beta.31",
    "next-intl": "^4.11.0",
    "openai": "^6.36.0",
    "p-queue": "^9.2.0",
    "prisma": "^6.19.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-select": "^5.10.2",
    "recharts": "^3.8.1",
    "resend": "^6.12.2",
    "shadcn": "^4.5.0",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "stripe": "^22.1.0",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0",
