{
  "installCommand": "npm ci",
  "buildCommand": "prisma generate && prisma migrate deploy && next build",
  "crons": [
    {
      "path": "/api/cron/wishlist-price-alerts",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/sync-stock",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/process-order-payouts",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/review-reminder",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/stripe-health",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/jobs/process-transfers",
      "schedule": "*/2 * * * *"
    }
  ]
}
