# Affisell Radar — template env (NE PAS committer de vrais secrets)
# Usage:
#   1) Copier les lignes manquantes vers .env.local (ne remplace PAS le fichier entier)
#   2) Remplacer YOUR_* par les vraies valeurs (Vercel / Partner consoles)
#   3) npm run radar:db:push
#
# Générateurs:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   openssl rand -hex 32

# --- Core Affisell ---
DATABASE_URL=postgresql://user:password@host:5432/db?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:password@host:5432/db?sslmode=require
NEXTAUTH_SECRET=YOUR_NEXTAUTH_SECRET_USE_OPENSSL_RAND_HEX_32

# --- Radar flags ---
RADAR_ENABLED=true
RADAR_PLANS_ENABLED=true
RADAR_DATABASE_URL=
RADAR_BETA_USER_IDS=

# --- Secrets Radar P0 ---
# AES-256-GCM : exactement 64 caractères hex (32 bytes) — openssl rand -hex 32
ENCRYPTION_KEY=YOUR_64_HEX_ENCRYPTION_KEY_GENERATE_WITH_openssl_rand_-hex_32
REDIS_URL=redis://user:password@host:port
CRON_SECRET=YOUR_CRON_SECRET_USE_OPENSSL_RAND_HEX_32

# --- Crawler / Trends (P1) ---
# Serper.dev → Dashboard → API Key (Google Search / Trends proxy)
SERPER_API_KEY=YOUR_SERPER_API_KEY
SERPAPI_API_KEY=
# Bearer for TikTok Shop search/trending crawler (Partner access_token OR Apify actor token)
TIKTOK_CRAWLER_ACCESS_TOKEN=YOUR_TIKTOK_CRAWLER_ACCESS_TOKEN
# Optional overrides if not using open-api.tiktokglobalshop.com defaults:
# TIKTOK_SHOP_SEARCH_URL=
# TIKTOK_SHOP_TRENDING_URL=
PROXY_URL=

# --- TikTok Shop — Affisell Analytics Connector ---
TIKTOK_SHOP_APP_KEY=YOUR_TIKTOK_SHOP_APP_KEY
TIKTOK_SHOP_APP_SECRET=YOUR_TIKTOK_SHOP_APP_SECRET
TIKTOK_SHOP_APP_ID=YOUR_TIKTOK_SHOP_APP_ID
TIKTOK_SHOP_REDIRECT_URI=https://affisell.com/api/intelli/tiktok/callback
TIKTOK_CLIENT_KEY=YOUR_TIKTOK_CLIENT_KEY
TIKTOK_CLIENT_SECRET=YOUR_TIKTOK_CLIENT_SECRET
TIKTOK_REDIRECT_URI=https://affisell.com/api/intelli/tiktok/callback

# --- Amazon SP-API LWA (P1) ---
AMAZON_LWA_CLIENT_ID=YOUR_AMAZON_LWA_CLIENT_ID
AMAZON_LWA_CLIENT_SECRET=YOUR_AMAZON_LWA_CLIENT_SECRET
AMAZON_SP_API_APPLICATION_ID=YOUR_AMAZON_SP_API_APPLICATION_ID
AMAZON_SP_API_ENDPOINT=https://sellingpartnerapi-eu.amazon.com
AMAZON_SP_API_ROLE_ARN=YOUR_AMAZON_SP_API_ROLE_ARN

# --- Google Merchant (P1) ---
# Paste real OAuth client id/secret only in .env.local / Vercel (never git).
GOOGLE_CLIENT_ID=YOUR_GOOGLE_OAUTH_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_OAUTH_CLIENT_SECRET
GOOGLE_REDIRECT_URI=https://affisell.com/api/radar/google/merchant/callback

# --- Alertes / Billing (P2) ---
# Paste the Incoming Webhook URL only in .env.local / Vercel (never git).
SLACK_WEBHOOK_URL=YOUR_SLACK_INCOMING_WEBHOOK_URL
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY
