# Local overrides — copy to `.env.local` (gitignored). Takes precedence over `.env`.
# Dev server: `npm run dev` → http://localhost:${PORT} (default PORT=3001 via scripts/next-dev-port.mjs).

# ── Port sync (keep all three aligned — run npm run verify:wizard-v2:dev) ──
PORT=3001
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXTAUTH_URL=http://localhost:3001

# Optional — cron/API scripts fallback when APP_URL unset
# APP_URL=http://localhost:3001

# ── Wizard v2 local dev ──
# Default off in prod; enable locally to skip ?wizard=v2 query param
ENABLE_WIZARD_V2=1

# Affisell InstantScan — wizard v2 Guided mode (POST /api/ai/analyze-product)
ENABLE_INSTANTSCAN=1
NEXT_PUBLIC_ENABLE_INSTANTSCAN=1
# Legacy retrocompat (server API if ENABLE_INSTANTSCAN unset)
# ENABLE_AI_VISION_V2=1
# NEXT_PUBLIC_ENABLE_AI_VISION_V2=1
OPENAI_API_KEY=""
PRODUCT_VISION_V2_MODEL=gpt-4o
AI_VISION_V2_CONFIDENCE_THRESHOLD=0.8
# Local Redis (optional — prod uses UPSTASH_REDIS_REST_URL + UPSTASH_REDIS_REST_TOKEN)
# REDIS_URL=redis://localhost:6379
# GROQ_API_KEY=""   # legacy v1 vision (Llama scout)

# PostHog wizard_v2_* events (optional)
# NEXT_PUBLIC_POSTHOG_KEY=""

# Database (local Docker: npm run db:local:setup)
# DATABASE_URL="postgresql://affisell:affisell@localhost:5433/affisell"

# Auth secrets — generate: openssl rand -base64 32
# NEXTAUTH_SECRET=""

# ── Shell-safe URLs (zsh glob on unquoted ?wizard=v2) ──
# Bad:  curl http://localhost:3001/dashboard/supplier/products/new?wizard=v2
# Good: curl "http://localhost:3001/dashboard/supplier/products/new?wizard=v2"
# Good: npm run dev:open:wizard-v2
# Good: npm run verify:wizard-v2:dev   → prints JSON-quoted URL
# Good: npm run test:wizard:v2         → unit tests + env preflight
