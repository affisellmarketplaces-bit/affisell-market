# Local overrides — copy to `.env.local` (gitignored). Takes precedence over `.env`.
# Dev server: `npm run dev` → http://localhost:3001 by default (see scripts/next-dev-port.mjs).

# Stable local port (must match NEXT_PUBLIC_APP_URL / NEXTAUTH_URL)
PORT=3001

# Public origin for emails, OAuth callbacks, storefront subdomains
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXTAUTH_URL=http://localhost:3001

# Optional — cron/API scripts fallback when APP_URL unset
# APP_URL=http://localhost:3001

# Database (local Docker: npm run db:local:setup)
# DATABASE_URL="postgresql://affisell:affisell@localhost:5433/affisell"

# Auth secrets — generate: openssl rand -base64 32
# NEXTAUTH_SECRET=""

# AI (supplier wizard v2 analyze-product)
# GROQ_API_KEY=""

# PostHog (optional — wizard_v2_* events)
# NEXT_PUBLIC_POSTHOG_KEY=""

# Wizard v2 canary (default off — use ?wizard=v2 or set to 1)
# ENABLE_WIZARD_V2=1

# Zsh tip: URLs with ?query must be quoted or use npm run dev:open:wizard-v2
# Bad:  curl http://localhost:3001/path?wizard=v2   (zsh glob error)
# Good: curl "http://localhost:3001/path?wizard=v2"
# Good: npm run dev:open:wizard-v2
